    <script>
      import { animate, inView, stagger, scroll } from 'motion'

      // Sticky nav shadow.
      const nav = document.getElementById('site-nav')
      if (nav) {
        const onScroll = () => nav.classList.toggle('is-scrolled', window.scrollY > 8)
        onScroll()
        window.addEventListener('scroll', onScroll, { passive: true })

        // Mobile menu toggle (links collapse behind a hamburger ≤768px).
        const toggle = nav.querySelector('.nav__toggle')
        const navLinks = document.getElementById('nav-links')
        if (toggle && navLinks) {
          const setOpen = (open) => {
            nav.classList.toggle('is-open', open)
            toggle.setAttribute('aria-expanded', open ? 'true' : 'false')
            toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu')
          }
          toggle.addEventListener('click', () => setOpen(!nav.classList.contains('is-open')))
          for (const a of navLinks.querySelectorAll('a')) a.addEventListener('click', () => setOpen(false))
          document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') setOpen(false)
          })
        }
      }

      // Copy-to-clipboard.
      for (const btn of document.querySelectorAll('.code-card__copy')) {
        btn.addEventListener('click', () => {
          const id = btn.getAttribute('data-copy')
          const target = id ? document.getElementById(id) : null
          if (!target) return
          navigator.clipboard
            ?.writeText(target.innerText)
            .then(() => {
              btn.textContent = 'Copied'
              btn.classList.add('is-copied')
              window.setTimeout(() => {
                btn.textContent = 'Copy'
                btn.classList.remove('is-copied')
              }, 1600)
            })
            .catch(() => {})
        })
      }

      // Read-progress rail.
      const rail = document.querySelector('.scroll-rail__fill')
      if (rail) scroll(animate(rail, { scaleX: [0, 1] }, { ease: 'linear' }))

      const reduce = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches
      if (!reduce) {
        const EASE = [0.16, 1, 0.3, 1]
        const hide = (els) => {
          for (const el of els) el.style.opacity = '0'
        }

        const reveal = (el, keyframes, opts = {}) => {
          if (!el) return
          el.style.opacity = '0'
          inView(
            el,
            () => animate(el, { opacity: [0, 1], ...keyframes }, { duration: 0.7, ease: EASE, ...opts }),
            { amount: 0.2 },
          )
        }
        const group = (container, childSel, keyframes) => {
          if (!container) return
          const kids = Array.from(container.querySelectorAll(childSel))
          hide(kids)
          inView(
            container,
            () =>
              animate(kids, { opacity: [0, 1], ...keyframes }, { delay: stagger(0.08), duration: 0.55, ease: EASE }),
            { amount: 0.15 },
          )
        }

        for (const head of document.querySelectorAll('.section__head')) reveal(head, { y: [22, 0] })
        group(document.querySelector('.bench-headline'), '.bench-headline__card', { y: [22, 0] })
        group(document.querySelector('.bento'), '.bento__cell', { y: [18, 0] })
        group(document.querySelector('.traj'), '.traj__step, .traj__arrow', { y: [18, 0] })

        // Grow each chart's bars (scaleX from the left) once it scrolls in.
        for (const chart of document.querySelectorAll('.chart')) {
          const fills = Array.from(chart.querySelectorAll('.bar__fill'))
          inView(
            chart,
            () => animate(fills, { scaleX: [0, 1] }, { delay: stagger(0.06), duration: 0.9, ease: EASE }),
            { amount: 0.3 },
          )
        }

        // Count-ups on every [data-count] (bars + headline figures).
        for (const el of document.querySelectorAll('[data-count]')) {
          const target = parseFloat(el.getAttribute('data-count') || '0')
          const decimals = parseInt(el.getAttribute('data-decimals') || '0', 10)
          const suffix = el.getAttribute('data-suffix') || ''
          let played = false
          inView(
            el,
            () => {
              if (played) return
              played = true
              animate(0, target, {
                duration: 1.1,
                ease: EASE,
                onUpdate: (v) => {
                  el.textContent = v.toFixed(decimals) + suffix
                },
              })
            },
            { amount: 0.6 },
          )
        }
      }
    </script>

