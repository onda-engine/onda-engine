      .bar__fill--onda.is-best {
        background: linear-gradient(90deg, var(--accent), #e89aab);
        box-shadow: 0 0 26px -6px rgba(217, 107, 130, 0.7);
      }
      .bar__val {
        font-family: var(--font-head);
        font-weight: 700;
        font-size: var(--fs-md);
        color: var(--text);
        text-align: right;
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
      }
      .chart-note {
        margin-top: var(--s-8);
        color: var(--text-muted);
        font-size: var(--fs-sm);
        max-width: 78ch;
      }
      /* Pre-collapse bars before paint so they grow in (only when motion is on). */
      :global(html.anim) .bar__fill {
        transform: scaleX(0);
      }

      /* ===================== 100x trajectory ===================== */
      .traj {
        display: grid;
        grid-template-columns: 1fr auto 1fr auto 1fr;
        align-items: stretch;
        gap: var(--s-6);
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .traj__step {
        display: flex;
        flex-direction: column;
        gap: var(--s-2);
        padding: var(--s-12) var(--s-8);
        border: 1px solid var(--border);
        border-radius: var(--r-card);
        background: var(--surface);
      }
      .traj__step--target {
        border-style: dashed;
        border-color: rgba(217, 107, 130, 0.5);
        background: repeating-linear-gradient(
          -45deg,
          transparent,
          transparent 9px,
          rgba(255, 255, 255, 0.015) 9px,
          rgba(255, 255, 255, 0.015) 10px
        );
      }
      .traj__num {
        font-family: var(--font-head);
        font-weight: 700;
        font-size: var(--fs-4xl);
        line-height: 1;
        letter-spacing: -0.02em;
        color: var(--accent);
      }
      .traj__num--target {
        color: var(--text-dim);
        -webkit-text-stroke: 1px var(--accent);
      }
      .traj__tag {
        align-self: flex-start;
        font-family: var(--font-code);
        font-size: 0.6rem;
        font-weight: 500;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--accent);
        border: 1px solid rgba(217, 107, 130, 0.4);
        border-radius: var(--r-pill);
        padding: 2px 8px;
      }
      .traj__k {
        font-weight: 600;
        color: var(--text);
        margin-top: var(--s-2);
      }
      .traj__v {
        color: var(--text-muted);
        font-size: var(--fs-sm);
      }
      .traj__arrow {
        display: grid;
        place-items: center;
        color: var(--text-dim);
        font-size: var(--fs-xl);
      }

      /* ===================== code-card (reproduce) ===================== */
      .code-card {
        margin: 0;
        background: var(--bg-deep);
        border: 1px solid var(--border);
        border-radius: var(--r-card);
        box-shadow: var(--elev-card);
        overflow: hidden;
      }
      .code-card__bar {
        display: flex;
        align-items: center;
        gap: var(--s-3);
        padding: var(--s-3) var(--s-4);
        background: var(--surface);
        border-bottom: 1px solid var(--border);
      }
      .code-card__dots {
        display: inline-flex;
        gap: 6px;
      }
      .code-card__dots i {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        background: var(--surface-2);
        border: 1px solid var(--border);
      }
      .code-card__file {
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        color: var(--text-muted);
      }
      .code-card__copy {
        margin-left: auto;
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-muted);
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        padding: var(--s-1) var(--s-3);
        border-radius: var(--r-control);
        min-height: 32px;
        cursor: pointer;
        transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease), background var(--dur) var(--ease);
      }
      .code-card__copy:hover {
        color: var(--text);
        border-color: #34343c;
        background: var(--surface-2);
      }
      .code-card__copy.is-copied {
        color: var(--accent);
        border-color: var(--accent);
      }
      .code-card__pre {
        margin: 0;
        padding: var(--s-6);
        overflow-x: auto;
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        line-height: 1.8;
        tab-size: 2;
      }
      .code-card__pre code {
        color: var(--text);
        white-space: pre;
        font-family: var(--font-code);
        background: none;
        padding: 0;
      }
      .tok-fn {
        color: var(--accent);
      }
      .tok-comment {
        color: var(--text-dim);
        font-style: italic;
      }
      .stats__foot {
        margin-top: var(--s-8);
        color: var(--text-muted);
        font-size: var(--fs-sm);
        max-width: 78ch;
      }

      /* ===================== CTA + footer ===================== */
      .cta {
        border-top: 1px solid var(--border);
        padding-block: var(--s-32);
      }
      .cta__inner {
        text-align: center;
        max-width: 60ch;
        margin-inline: auto;
      }
      .cta__title {
        font-size: var(--fs-3xl);
        font-weight: 600;
        margin-bottom: var(--s-6);
        letter-spacing: -0.02em;
      }
      .cta__sub {
        color: var(--text-muted);
        font-size: var(--fs-md);
        margin-bottom: var(--s-8);
      }

      .footer {
        padding-top: var(--s-20);
        border-top: 1px solid var(--border);
      }
      .footer__inner {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: var(--s-8);
        padding-bottom: var(--s-16);
      }
      .footer__tag {
        color: var(--text-muted);
        margin-top: var(--s-4);
        max-width: 38ch;
      }
      .footer__nav {
        display: flex;
        flex-direction: column;
        gap: var(--s-3);
      }
      .footer__col-title {
        font-family: var(--font-head);
        font-size: var(--fs-base);
        font-weight: 600;
        color: var(--text);
        margin-bottom: var(--s-3);
      }
      .footer__nav a {
        color: var(--text-muted);
        font-weight: 500;
      }
      .footer__nav a:hover {
        color: var(--text);
      }
      .footer__bottom {
        display: flex;
        flex-wrap: wrap;
        gap: var(--s-4);
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid var(--border);
        padding-block: var(--s-6);
        color: var(--text-muted);
        font-size: var(--fs-sm);
      }
      .footer__bottom a {
        color: var(--text-muted);
        font-family: var(--font-code);
      }
      .footer__bottom a:hover {
        color: var(--accent);
      }
      .footer__legal {
        padding-block: var(--s-2) var(--s-16);
      }
      .footer__legal p {
        color: var(--text-dim);
        font-size: 0.78rem;
        line-height: 1.65;
        max-width: 92ch;
      }
      .footer__legal a {
        color: var(--text-dim);
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      .footer__legal a:hover {
        color: var(--text-muted);
      }

      /* ===================== Ambient drift (motion only) ===================== */
      @media (prefers-reduced-motion: no-preference) {
        .atmos__blob--rose {
          animation: atmos-drift 20s ease-in-out infinite alternate;
        }
        .atmos__blob--violet {
          animation: atmos-drift 26s ease-in-out infinite alternate-reverse;
        }
        .atmos__blob--deep {
          animation: atmos-drift 32s ease-in-out infinite alternate;
        }
        /* The Studio pill gently breathes its glow to draw the eye (pauses on hover). */
        .onda-landing .nav__links a.nav__studio-link {
          animation: studio-pulse 3.2s ease-in-out infinite;
        }
        .onda-landing .nav__links a.nav__studio-link:hover {
          animation-play-state: paused;
        }
        .nav__studio-spark {
          animation: studio-spark 3.2s ease-in-out infinite;
        }
      }
      @keyframes atmos-drift {
        from {
          transform: translate3d(0, 0, 0);
        }
        to {
          transform: translate3d(4%, -3%, 0);
        }
      }
      @keyframes studio-pulse {
        0%,
        100% {
          box-shadow: 0 0 0 1px rgba(176, 108, 255, 0.45), 0 6px 22px -6px var(--studio-glow);
        }
        50% {
          box-shadow: 0 0 0 1px var(--studio), 0 8px 30px 0 rgba(176, 108, 255, 0.55);
        }
      }
      @keyframes studio-spark {
        0%,
        100% {
          transform: rotate(0deg) scale(1);
          opacity: 0.85;
        }
        50% {
          transform: rotate(90deg) scale(1.18);
          opacity: 1;
        }
      }

      /* ===================== Responsive ===================== */
      @media (max-width: 1024px) {
        .footer__inner {
          grid-template-columns: 1fr 1fr;
        }
        .footer__brand {
          grid-column: 1 / -1;
        }
      }
      @media (max-width: 768px) {
        .section {
          padding-block: var(--s-20);
        }
        .section__title,
        .cta__title {
          font-size: var(--fs-2xl);
        }
        .bench-headline,
        .bento {
          grid-template-columns: 1fr;
        }
        .bento__cell--wide {
          grid-column: auto;
        }
        .nav__toggle {
          display: inline-flex;
          margin-left: auto;
        }
        .nav__links {
          display: none;
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          flex-direction: column;
          gap: 0;
          margin-left: 0;
          padding: var(--s-2) var(--s-6) var(--s-4);
          background: var(--bg);
          border-bottom: 1px solid var(--border);
          box-shadow: 0 24px 48px -24px rgba(0, 0, 0, 0.7);
        }
        .nav.is-open .nav__links {
          display: flex;
        }
        .nav__links a:not(.nav__studio-link) {
          min-height: 48px;
          display: flex;
          align-items: center;
          padding: var(--s-2) 0;
          border-bottom: 1px solid var(--border);
        }
        /* Studio stays a pill — full-width, centered, as the menu's standout CTA. */
        .onda-landing .nav__links a.nav__studio-link {
          justify-content: center;
          margin-top: var(--s-4);
          padding-block: 11px;
        }
        /* Trajectory stacks vertically; arrows rotate to point down. */
        .traj {
          grid-template-columns: 1fr;
        }
        .traj__arrow {
          transform: rotate(90deg);
          padding: var(--s-2) 0;
        }
        /* Bars: name on its own line above the track. */
        .bar {
          grid-template-columns: 1fr auto;
          grid-template-areas: 'name name' 'track val';
          gap: var(--s-2) var(--s-4);
        }
        .bar__name {
          grid-area: name;
        }
        .bar__track {
          grid-area: track;
        }
        .bar__val {
          grid-area: val;
        }
      }
      @media (max-width: 480px) {
        .container {
          padding-inline: var(--s-4);
        }
        .footer__inner {
          grid-template-columns: 1fr;
        }
        .code-card__pre {
          font-size: 0.78rem;
          padding: var(--s-4);
        }
      }
    </style>
  </body>
</html>
