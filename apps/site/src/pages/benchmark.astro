---
// ONDA benchmark — the proof page. A standalone static page in the landing's
// design language (shares the .onda-landing token system, nav and footer). All
// numbers are synced to the repository suite (apps/benchmark/README.md): an
// apples-to-apples render of an equivalent 1080p composition on one machine,
// scaled from a trivial scene (1 cluster / 6 nodes) to a complex one (40
// clusters / 201 nodes). Higher fps is better.
const REPO = 'https://github.com/onda-engine/onda-engine'
const BENCH = `${REPO}/tree/main/apps/benchmark`
const STUDIO_URL = 'https://studio.onda.video'
const year = new Date().getFullYear()

// --- Data (Apple M4 Pro, 1920×1080, 120 frames; one warm-up). fps; higher = better.
type Row = { label: string; fps: number; ms: number; kind: 'onda' | 'remotion'; best?: boolean }

// Raster throughput — draw only (no encode).
const rasterTrivial: Row[] = [
  { label: 'ONDA · CPU (all cores)', fps: 865.6, ms: 1.16, kind: 'onda' },
  { label: 'ONDA · GPU (Vello)', fps: 298.0, ms: 3.36, kind: 'onda', best: true },
  { label: 'ONDA · CPU (1 thread)', fps: 101.8, ms: 9.82, kind: 'onda' },
  { label: 'Remotion · default pool', fps: 85.5, ms: 11.69, kind: 'remotion' },
  { label: 'Remotion · 1 worker', fps: 26.8, ms: 37.3, kind: 'remotion' },
]
const rasterComplex: Row[] = [
  { label: 'ONDA · GPU (Vello)', fps: 217.4, ms: 4.6, kind: 'onda', best: true },
  { label: 'ONDA · CPU (all cores)', fps: 116.3, ms: 8.6, kind: 'onda' },
  { label: 'Remotion · default pool', fps: 56.7, ms: 17.63, kind: 'remotion' },
  { label: 'Remotion · 1 worker', fps: 25.7, ms: 38.88, kind: 'remotion' },
  { label: 'ONDA · CPU (1 thread)', fps: 11.7, ms: 85.32, kind: 'onda' },
]
// Full pipeline — render + readback + encode → mp4 (the number an export costs).
const exportTrivial: Row[] = [
  { label: 'ONDA · Vello + libx264', fps: 145.8, ms: 6.86, kind: 'onda', best: true },
  { label: 'ONDA · Vello + HW encode', fps: 98.7, ms: 10.13, kind: 'onda' },
  { label: 'Remotion · default pool', fps: 83.9, ms: 11.93, kind: 'remotion' },
  { label: 'Remotion · 1 worker', fps: 26.9, ms: 37.24, kind: 'remotion' },
]
const exportComplex: Row[] = [
  { label: 'ONDA · Vello + libx264', fps: 107.6, ms: 9.29, kind: 'onda', best: true },
  { label: 'ONDA · Vello + HW encode', fps: 80.5, ms: 12.42, kind: 'onda' },
  { label: 'Remotion · default pool', fps: 58.9, ms: 16.98, kind: 'remotion' },
  { label: 'Remotion · 1 worker', fps: 26.1, ms: 38.24, kind: 'remotion' },
]
const maxOf = (rows: Row[]) => Math.max(...rows.map((r) => r.fps))
const charts = [
  { id: 'raster-trivial', rows: rasterTrivial },
  { id: 'raster-complex', rows: rasterComplex },
  { id: 'export-trivial', rows: exportTrivial },
  { id: 'export-complex', rows: exportComplex },
]
const maxes = Object.fromEntries(charts.map((c) => [c.id, maxOf(c.rows)]))
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ONDA — Benchmark: GPU-native vs the browser pipeline</title>
    <meta
      name="description"
      content="Apples-to-apples render benchmarks: ONDA's GPU-native pipeline vs Remotion's headless-browser pipeline, on the same machine, same scene, same encoder. Reproducible."
    />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0e0e12" />
    {/* Inline (not bundled) so the dark canvas paints on the very first frame —
        prevents a background flash on reload before the scoped CSS loads. */}
    <style is:inline>
      html,
      body {
        margin: 0;
        background: #0e0e12;
      }
    </style>
    <meta property="og:type" content="website" />
    <meta property="og:title" content="ONDA — Benchmark: GPU-native vs the browser pipeline" />
    <meta
      property="og:description"
      content="Apples-to-apples render benchmarks against Remotion — same machine, same scene, same encoder. Reproducible."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=clash-display@600,700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      if (!window.matchMedia || !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('anim')
      }
    </script>
    <script>
      if (import.meta.env.DEV) import('react-grab')
    </script>
  </head>
  <body>
    <div class="onda-landing">
      <a class="skip-link" href="#main">Skip to content</a>
      <div class="scroll-rail" aria-hidden="true"><span class="scroll-rail__fill"></span></div>
      <div class="atmos" aria-hidden="true">
        <span class="atmos__blob atmos__blob--rose"></span>
        <span class="atmos__blob atmos__blob--violet"></span>
        <span class="atmos__blob atmos__blob--deep"></span>
      </div>

      <!-- ============ STICKY NAV ============ -->
      <header class="nav" id="site-nav">
        <div class="container nav__inner">
          <a class="brand" href="/" aria-label="ONDA — home">
            <img class="brand__mark-img" src="/onda-mark.svg" alt="" width="88" height="22" />
            <span class="brand__word">ONDA</span>
          </a>
          <nav class="nav__links" id="nav-links" aria-label="Primary">
            <a href="/#features">Features</a>
            <a href="/components">Components</a>
            <a href="/transitions">Transitions</a>
            <a href="/effects">Effects</a>
            <a href="/guide/introduction">Docs</a>
            <a class="nav__studio-link" href={STUDIO_URL} rel="noopener">
              <svg class="nav__studio-spark" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l1.9 6.6L20 10.5l-6.1 1.9L12 19l-1.9-6.6L4 10.5l6.1-1.9z"/></svg>
              Studio
            </a>
          </nav>
          <button class="nav__toggle" type="button" aria-expanded="false" aria-controls="nav-links" aria-label="Open menu">
            <svg class="nav__toggle-bars" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
            <svg class="nav__toggle-x" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 5l14 14M19 5 5 19"/></svg>
          </button>
        </div>
      </header>

      <main id="main">
        <!-- ============ INTRO ============ -->
        <section class="bench-hero">
          <div class="container">
            <p class="eyebrow"><span class="eyebrow__tick">●</span> Benchmark</p>
            <h1 class="bench-hero__title">ONDA vs Remotion, <span class="accent-text">measured</span>.</h1>
            <p class="bench-hero__sub">
              The same 1080p composition, rendered on the same machine, with the same encoder. ONDA
              draws natively on the GPU; Remotion drives every frame through a headless browser. The
              numbers below are from the repo's reproducible suite — higher fps is better.
            </p>
            <div class="bench-hero__actions">
              <a class="btn btn--primary" href="#reproduce">Reproduce it ↓</a>
              <a class="btn btn--ghost" href={BENCH} rel="noopener">
                <svg class="btn__icon" width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                  <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.4 7.4 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z" />
                </svg>
                Benchmark source
              </a>
            </div>

            <!-- The headline contrast that explains every chart below. -->
            <div class="bench-headline">
              <article class="bench-headline__card">
                <p class="bench-headline__num" data-count="26" data-decimals="0" data-suffix=" fps">26 fps</p>
                <p class="bench-headline__k">Remotion, per worker</p>
                <p class="bench-headline__v">Holds ~26 fps whether the scene has <strong>6 nodes or 201</strong> — you pay the browser tax, not for the drawing.</p>
              </article>
              <article class="bench-headline__card bench-headline__card--us">
                <p class="bench-headline__num"><span class="accent-text" data-count="217" data-decimals="0" data-suffix=" fps">217 fps</span></p>
                <p class="bench-headline__k">ONDA GPU, the heavy scene</p>
                <p class="bench-headline__v">Renders the <strong>33× heavier</strong> scene only 1.4× slower than trivial. Cost tracks the graphics, not the browser.</p>
              </article>
            </div>
          </div>
        </section>

        <!-- ============ METHODOLOGY (bento) ============ -->
        <section class="section section--alt" aria-labelledby="method-title">
          <div class="container">
            <header class="section__head">
              <p class="eyebrow">How it's measured</p>
              <h2 id="method-title" class="section__title">Same scene. Same machine. Same encoder.</h2>
              <p class="section__lede">
                <code>onda-bench</code>'s <code>cluster(i)</code> and Remotion's <code>&lt;Cluster i&gt;</code>
                use identical geometry and scatter formula, so the two stay directly comparable as the
                scene scales from trivial to complex.
              </p>
            </header>
            <ul class="bento" role="list">
              <li class="bento__cell"><span class="bento__k">Apple M4 Pro</span><span class="bento__v">macOS, same machine for both</span></li>
              <li class="bento__cell"><span class="bento__k">1920 × 1080</span><span class="bento__v">120 frames, one warm-up</span></li>
              <li class="bento__cell"><span class="bento__k">libx264</span><span class="bento__v">identical encoder on both engines</span></li>
              <li class="bento__cell bento__cell--wide"><span class="bento__k">The scene: a cluster</span><span class="bento__v">two translucent discs, an accent bar, a title and a subtitle. <code>repeats</code> scatters N identical clusters — from 1 (6 nodes) to 40 (201 nodes, heavy overdraw + 80 text runs).</span></li>
              <li class="bento__cell"><span class="bento__k">Steady-state</span><span class="bento__v">measured after warm-up; small run-to-run variance</span></li>
            </ul>
          </div>
        </section>

        <!-- ============ RASTER THROUGHPUT ============ -->
        <section class="section" aria-labelledby="raster-title">
          <div class="container">
            <header class="section__head">
              <p class="eyebrow">Raster throughput · draw only</p>
              <h2 id="raster-title" class="section__title">Remotion's cost is flat. ONDA's tracks the scene.</h2>
              <p class="section__lede">
                Pure drawing throughput, before any encode. On a trivial scene ONDA already pulls
                ahead; on a complex one the gap widens — because Remotion pays a fixed browser tax
                per frame while ONDA only pays for what it actually draws.
              </p>
            </header>

            <div class="chart-block">
              <div class="chart-block__head">
                <h3 class="chart-block__title">Trivial scene <span class="chart-block__meta">1 cluster · 6 nodes · Remotion's best case</span></h3>
                <span class="chart-legend"><i class="chart-legend__sw chart-legend__sw--onda"></i>ONDA<i class="chart-legend__sw chart-legend__sw--them"></i>Remotion</span>
              </div>
              <div class="chart" id="raster-trivial" role="list" aria-label="Trivial scene render throughput, frames per second">
                {rasterTrivial.map((r) => (
                  <div class="bar" style={`--w:${r.fps / maxes['raster-trivial']}`} role="listitem" aria-label={`${r.label}: ${r.fps} frames per second`}>
                    <span class="bar__name">{r.label}</span>
                    <div class="bar__track"><span class={`bar__fill ${r.kind === 'onda' ? 'bar__fill--onda' : 'bar__fill--them'}${r.best ? ' is-best' : ''}`}></span></div>
                    <span class="bar__val" data-count={r.fps} data-decimals="1" data-suffix=" fps">{r.fps.toFixed(1)} fps</span>
                  </div>
                ))}
              </div>
            </div>

            <div class="chart-block">
              <div class="chart-block__head">
                <h3 class="chart-block__title">Complex scene <span class="chart-block__meta">40 clusters · 201 nodes · heavy overdraw</span></h3>
                <span class="chart-legend"><i class="chart-legend__sw chart-legend__sw--onda"></i>ONDA<i class="chart-legend__sw chart-legend__sw--them"></i>Remotion</span>
              </div>
              <div class="chart" id="raster-complex" role="list" aria-label="Complex scene render throughput, frames per second">
                {rasterComplex.map((r) => (
                  <div class="bar" style={`--w:${r.fps / maxes['raster-complex']}`} role="listitem" aria-label={`${r.label}: ${r.fps} frames per second`}>
                    <span class="bar__name">{r.label}</span>
                    <div class="bar__track"><span class={`bar__fill ${r.kind === 'onda' ? 'bar__fill--onda' : 'bar__fill--them'}${r.best ? ' is-best' : ''}`}></span></div>
                    <span class="bar__val" data-count={r.fps} data-decimals="1" data-suffix=" fps">{r.fps.toFixed(1)} fps</span>
                  </div>
                ))}
              </div>
              <p class="chart-note">
                Honest caveat: ONDA's <strong>CPU</strong> reference rasterizer is software and
                overdraw-bound, so it falls behind on heavy scenes — use the GPU path for those. The
                GPU renders the 33×-heavier scene only 1.4× slower than trivial.
              </p>
            </div>
          </div>
        </section>

        <!-- ============ FULL EXPORT ============ -->
        <section class="section section--alt" aria-labelledby="export-title">
          <div class="container">
            <header class="section__head">
              <p class="eyebrow">Full pipeline · render → MP4</p>
              <h2 id="export-title" class="section__title">What an export actually costs</h2>
              <p class="section__lede">
                End-to-end: GPU render, readback, and the same <code>libx264</code> encode both engines
                use. One single-threaded ONDA process still beats Remotion's whole multi-worker pool.
              </p>
            </header>

            <div class="chart-block">
              <div class="chart-block__head">
                <h3 class="chart-block__title">Trivial scene <span class="chart-block__meta">1 cluster · full export → mp4</span></h3>
                <span class="chart-legend"><i class="chart-legend__sw chart-legend__sw--onda"></i>ONDA<i class="chart-legend__sw chart-legend__sw--them"></i>Remotion</span>
              </div>
              <div class="chart" id="export-trivial" role="list" aria-label="Trivial scene full export throughput, frames per second">
                {exportTrivial.map((r) => (
                  <div class="bar" style={`--w:${r.fps / maxes['export-trivial']}`} role="listitem" aria-label={`${r.label}: ${r.fps} frames per second`}>
                    <span class="bar__name">{r.label}</span>
                    <div class="bar__track"><span class={`bar__fill ${r.kind === 'onda' ? 'bar__fill--onda' : 'bar__fill--them'}${r.best ? ' is-best' : ''}`}></span></div>
                    <span class="bar__val" data-count={r.fps} data-decimals="1" data-suffix=" fps">{r.fps.toFixed(1)} fps</span>
                  </div>
                ))}
              </div>
            </div>

            <div class="chart-block">
              <div class="chart-block__head">
                <h3 class="chart-block__title">Complex scene <span class="chart-block__meta">40 clusters · full export → mp4</span></h3>
                <span class="chart-legend"><i class="chart-legend__sw chart-legend__sw--onda"></i>ONDA<i class="chart-legend__sw chart-legend__sw--them"></i>Remotion</span>
              </div>
              <div class="chart" id="export-complex" role="list" aria-label="Complex scene full export throughput, frames per second">
                {exportComplex.map((r) => (
                  <div class="bar" style={`--w:${r.fps / maxes['export-complex']}`} role="listitem" aria-label={`${r.label}: ${r.fps} frames per second`}>
                    <span class="bar__name">{r.label}</span>
                    <div class="bar__track"><span class={`bar__fill ${r.kind === 'onda' ? 'bar__fill--onda' : 'bar__fill--them'}${r.best ? ' is-best' : ''}`}></span></div>
                    <span class="bar__val" data-count={r.fps} data-decimals="1" data-suffix=" fps">{r.fps.toFixed(1)} fps</span>
                  </div>
                ))}
              </div>
              <p class="chart-note">
                With libx264 on both, one ONDA process exports <strong>~5.4×</strong> faster than a
                Remotion worker on the trivial scene and <strong>~4.1×</strong> on the complex one —
                and ~1.7–1.8× faster than Remotion's whole pool, single-threaded. Hardware encode is
                <em>slower</em> here: VideoToolbox's per-call overhead loses to libx264 on short clips
                (it pays off at 4K / long renders), so libx264 stays the portable default.
              </p>
            </div>
          </div>
        </section>

        <!-- ============ THE 100x TRAJECTORY ============ -->
        <section class="section" aria-labelledby="traj-title">
          <div class="container">
            <header class="section__head">
              <p class="eyebrow">The trajectory</p>
              <h2 id="traj-title" class="section__title">Measured multiples today. A 100× architectural ceiling.</h2>
              <p class="section__lede">
                The per-thread gap already grows with scene complexity. The <strong>100×</strong> figure
                is the realized goal on real workloads — it comes from what this microbenchmark doesn't
                capture: cold-start (ONDA ~ms vs a Chromium launch + bundle + warmup), a real-time GPU
                present, and offloaded codec work. It's a target, not a single-scene result.
              </p>
            </header>
            <ol class="traj" aria-label="Performance trajectory from measured to target">
              <li class="traj__step">
                <span class="traj__num">3.8×</span>
                <span class="traj__k">trivial scene</span>
                <span class="traj__v">per thread · ONDA CPU vs a Remotion worker</span>
              </li>
              <li class="traj__arrow" aria-hidden="true">→</li>
              <li class="traj__step">
                <span class="traj__num">8.5×</span>
                <span class="traj__k">complex scene</span>
                <span class="traj__v">per thread · ONDA GPU vs a Remotion worker</span>
              </li>
              <li class="traj__arrow" aria-hidden="true">→</li>
              <li class="traj__step traj__step--target">
                <span class="traj__num traj__num--target">100×</span>
                <span class="traj__tag">target</span>
                <span class="traj__k">architectural ceiling</span>
                <span class="traj__v">complex × GPU present × cold-start × concurrency — not a single benchmark</span>
              </li>
            </ol>
          </div>
        </section>

        <!-- ============ REPRODUCE ============ -->
        <section class="section section--alt" id="reproduce" aria-labelledby="repro-title">
          <div class="container">
            <header class="section__head">
              <p class="eyebrow">Reproduce</p>
              <h2 id="repro-title" class="section__title">Run it yourself</h2>
              <p class="section__lede">
                No performance claim without a benchmark. The full harness lives in the repo — clone it
                and run both engines on your own hardware.
              </p>
            </header>
            <figure class="code-card" aria-label="Commands to run the ONDA and Remotion benchmarks">
              <figcaption class="code-card__bar">
                <span class="code-card__dots" aria-hidden="true"><i></i><i></i><i></i></span>
                <span class="code-card__file">benchmark</span>
                <button class="code-card__copy" type="button" data-copy="bench-code" aria-label="Copy commands to clipboard">Copy</button>
              </figcaption>
              <pre class="code-card__pre"><code id="bench-code"><span class="tok-comment"># ONDA (Rust, CPU + GPU backends) — args: &lt;frames&gt; &lt;clusters&gt;</span>
<span class="tok-fn">cargo</span> run --release -p onda-bench -- 120 1      <span class="tok-comment"># trivial</span>
<span class="tok-fn">cargo</span> run --release -p onda-bench -- 120 40     <span class="tok-comment"># complex</span>

<span class="tok-comment"># Remotion (React → headless Chromium → screenshot → encode)</span>
<span class="tok-fn">pnpm</span> --filter benchmark bench 1
<span class="tok-fn">pnpm</span> --filter benchmark bench 40

<span class="tok-comment"># ONDA full export (Vello raster + readback + encode → mp4)</span>
<span class="tok-fn">pnpm</span> --filter benchmark bench:onda 120 1
<span class="tok-fn">pnpm</span> --filter benchmark bench:onda 120 40</code></pre>
            </figure>
            <p class="stats__foot">
              Numbers on this page are steady-state on an Apple M4 Pro and vary a little run-to-run and
              by hardware, scene and configuration. <a href={BENCH} rel="noopener">Full method, tables &amp; source →</a>
            </p>
          </div>
        </section>

        <!-- ============ CTA ============ -->
        <section class="cta" aria-labelledby="cta-title">
          <div class="container cta__inner">
            <h2 id="cta-title" class="cta__title">Render your first frame without a browser</h2>
            <p class="cta__sub">Clone the repo, write a composition, ship a video. The source is all public.</p>
            <a class="btn btn--primary btn--lg" href="/guide/getting-started">Get started</a>
          </div>
        </section>
      </main>

      <!-- ============ FOOTER ============ -->
      <footer class="footer">
        <div class="container footer__inner">
          <div class="footer__brand">
            <a class="brand" href="/" aria-label="ONDA — home">
              <img class="brand__mark-img" src="/onda-mark.svg" alt="" width="80" height="20" />
              <span class="brand__word">ONDA</span>
            </a>
            <p class="footer__tag">The rendering foundation for the next decade of motion graphics.</p>
          </div>
          <nav class="footer__nav" aria-label="Footer">
            <h3 class="footer__col-title">Project</h3>
            <a href="/#features">Features</a>
            <a href="/components">Components</a>
            <a href="/transitions">Transitions</a>
            <a href="/effects">Effects</a>
            <a href="/benchmark">Benchmark</a>
            <a href="/guide/introduction">Docs</a>
          </nav>
          <nav class="footer__nav" aria-label="Resources">
            <h3 class="footer__col-title">Resources</h3>
            <a href={REPO} rel="noopener">GitHub repository</a>
            <a href="/guide/getting-started">Getting started</a>
            <a href={BENCH} rel="noopener">Benchmark source</a>
            <a href={`${REPO}/blob/main/LICENSE`} rel="noopener">License</a>
          </nav>
        </div>
        <div class="container footer__bottom">
          <p>© {year} ONDA. Source-available under <strong>FSL-1.1-Apache-2.0</strong>.</p>
          <a href={REPO} rel="noopener">github.com/onda-engine/onda-engine</a>
        </div>
        <div class="container footer__legal">
          <p>
            ONDA Engine is an independent, source-available project — not affiliated with, endorsed by,
