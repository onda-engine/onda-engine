---
// The ONDA effects showcase — the render-to-texture node effects (blur, bloom,
// grade, goo), each played live by the engine (Vello/WebGPU, CPU fallback).
// Standalone page (not a Starlight doc) so the player can use a full-width layout.
import EffectsGallery from '../components/EffectsGallery.tsx'
const REPO = 'https://github.com/degueba/onda-engine'

// Cinematic finishing — the export/native premium moves whose before/after is a
// rendered still (the live preview degrades them). Update this list when a new
// export-only effect ships (with a before/after + an accurate blurb).
const CINEMATIC = {
  eyebrow: 'CINEMATIC FINISHING',
  title: 'The finishing pass — exported, native, premium-tier.',
  intro:
    'These are the export/native finishing moves — the difference lives in the GPU compute pass, so the live page degrades them (fBm falls back to a smooth gradient, the cinematic finish to its raw gamma frame, light-wrap to the un-wrapped node) and each before/after is an exported still. The one exception is morphPath: pure authoring, zero engine change, so it plays live.',
  entries: [
    {
      title: 'fBm gradient',
      blurb:
        'Left, a flat 2-stop linear ramp. Right, the SAME stops as an fBm gradient — the soft, flowing Stripe/Linear-tier surface that reads "expensive," the tell that a backdrop was art-directed, not just filled. Fractal Brownian motion over 2D Simplex noise plus a domain-warp, run as a GPU compute pass; animate time for a living surface.',
      snippet:
        '<Rect width={W} height={H} fill={fbmGradient(stops, { scale: 1, warp: 0.5, time: frame / fps })} />',
      before: { src: '/effects/fbm-before.png', label: 'flat linear' },
      after: { src: '/effects/fbm-after.png', label: 'fBm' },
    },
    {
      title: 'Cinematic finish — one prop, the whole chain',
      blurb:
        'The "looks shot" output transform as a SINGLE Composition prop. <code>finish</code> runs the entire finishing chain in scene-linear light with HDR headroom, ending in ONE ACES film tone-map — landing the whole comp as one photographed image instead of a stack of separate filters. Here, left→right: bloom bleeding REAL light (highlights exceed 1.0 and roll off, not a clamped overlay), a warm halation fringe, a film grade (white-balance + contrast + saturation), a drawn-in vignette, and fine luminance-banded grain — all composited together and tone-mapped ONCE. The key move: unlike per-node effects (Vello hands those back 8-bit between passes, so the HDR is lost), the finish decodes to float and keeps everything in linear HDR right up to the single tone-map.',
      snippet: `<Composition
  finish={{
    bloom: { sigma: 18, intensity: 2.4 }, halation: 0.7,
    temperature: 0.22, contrast: 1.12, vignette: 0.42, grain: 0.05,
  }}
>
  <Plate />
</Composition>`,
      before: { src: '/effects/linear-before.png', label: 'raw · gamma' },
      after: { src: '/effects/linear-after.png', label: 'finish' },
    },
    {
      title: 'Motion blur — shutter-angle, per object',
      blurb:
        'The single biggest "amateur vs pro" tell in motion. One prop on the Composition — <code>motionBlur</code> — and every output frame becomes the average of N sub-frames spread across the shutter window, so anything that MOVES smears by its own motion while static elements stay razor-sharp. Left, frame 8 rendered once; right, the same instant averaged over an 180° shutter: the circle smears along its travel, the square’s corners smear from its spin, the "MOTION" text (static) stays crisp. It’s true temporal supersampling, so it catches translation, rotation, scale — anything that’s a function of the frame — not just a velocity streak. Cost is N× the render, so it lands at export (the live preview shows the sharp frame).',
      snippet: `<Composition motionBlur={{ shutter: 180, samples: 16 }}>
  <FastMove />
</Composition>`,
      before: { src: '/effects/motionblur-before.png', label: '1 sample · sharp' },
      after: { src: '/effects/motionblur-after.png', label: '180° · 18 samples' },
    },
    {
      title: 'Depth of field — a 2.5D rack focus',
      blurb:
        'Give each layer a <code>depth</code> and the Composition a <code>dof={{ focus }}</code>, and every layer defocuses by how far its depth is from the focus plane — the lens move that separates a subject from its world and guides the eye. Left, everything in focus (flat); right, focus pulled to the SUBJECT card: the far dot-field melts to a soft wash, and the near orbs bloom into round bokeh. Animate <code>focus</code> for a rack-focus pull between layers. It resolves to a per-layer blur (it reuses the blur pass, so it works on both backends and the live preview), and the depth is yours to assign — no true 3D required.',
      snippet: `<Composition dof={{ focus: 400, aperture: 0.06 }}>
  <Group depth={900}><Background /></Group>
  <Group depth={400}><Subject /></Group>
  <Group depth={120}><Foreground /></Group>
</Composition>`,
      before: { src: '/effects/dof-before.png', label: 'no dof · flat' },
      after: { src: '/effects/dof-after.png', label: 'focus → subject' },
    },
    {
      title: 'Light-wrap',
      blurb:
        'A cut-out subject dropped onto a background fools no one — the edges are too clean. Light-wrap is the fix every compositor reaches for: the blurred background light bleeds a few pixels onto the subject\'s silhouette, in linear light, so it reads as SHOT IN the scene rather than pasted on top. Left, a hard dark cut-out on a vivid plate; right, the same shape with the surrounding colour drawn onto its inner edge. The #1 tell for landing AI-generated or stock media inside a composition.',
      snippet: '<Image src="subject.png" lightWrap={{ sigma: 30, strength: 1 }} />',
      before: { src: '/effects/lightwrap-before.png', label: 'pasted on' },
      after: { src: '/effects/lightwrap-after.png', label: 'light-wrap' },
    },
    {
      title: 'Film grain',
      blurb:
        'The compositing glue — and the dither that saves a dark-gradient hero. A luminance-banded monochrome noise laid over the frame: it ties mismatched sources (an AI plate, a real product, vector type) into one photographed image, and it breaks up the 8-bit banding that stripes a deep gradient. Left, a clean-digital gradient with latent banding; right, the same frame with a fine filmic grain. It peaks in the midtones and stays clean at pure black and white — and unlike the moves above, it renders identically on the CPU reference, so the preview is never blind to it.',
      snippet: '<Group grain={{ intensity: 0.04, size: 1.2, seed: frame }}>…</Group>',
      before: { src: '/effects/grain-before.png', label: 'clean · banding' },
      after: { src: '/effects/grain-after.png', label: 'film grain' },
    },
    {
      title: 'morphPath',
      blurb:
        'A circle continuously morphing into a rule — one element transforming into another, the Apple/ElevenLabs "magic move" that reads as a single object, not a crossfade. morphPath(from, to, t) returns the in-between path for an animated t; flubber solves the hard part — point CORRESPONDENCE between the two outlines (a naive d-string lerp tears shapes apart). Zero engine change, so it plays live.',
      snippet: '<Path d={morphPath(CIRCLE, RULE, ramp(frame, 70, 95))} fill="#fff" />',
      strip: '/effects/morph-strip.png',
      stripLabel: 'circle → rule, five stages of one morph',
    },
  ],
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Effects — ONDA</title>
    <meta
      name="description"
      content="Render-to-texture effects — blur, bloom, color grade, gooey morph — applied to any node and played live in your browser by the ONDA GPU engine."
    />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0e0e12" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=clash-display@600,700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="gallery-page">
      <header class="gnav">
        <a class="brand" href="/" aria-label="ONDA — home">
          <img src="/onda-mark.svg" alt="" width="80" height="20" />
          <span>ONDA</span>
        </a>
        <nav class="gnav__links" aria-label="Primary">
          <a href="/">Home</a>
          <a href="/components">Components</a>
          <a href="/transitions">Transitions</a>
          <a href="/effects" aria-current="page">Effects</a>
          <a href="/guide/introduction">Docs</a>
          <a href={REPO} rel="noopener">GitHub</a>
        </nav>
      </header>

      <main class="gmain">
        <header class="ghead">
          <p class="eyebrow">Render-to-texture</p>
          <h1>Effects, rendered by the engine.</h1>
          <p class="lede">
            Effects render to a texture, get processed on the GPU, and composite back — by the same
            engine that exports your video. Two views: play with the per-node effects live, or see the
            export-only <strong>cinematic finishing</strong> passes.
          </p>
        </header>

        <div class="tabs" role="tablist" aria-label="Effects views">
          <button
            class="tab is-active"
            type="button"
            role="tab"
            id="tab-live"
            aria-selected="true"
            aria-controls="panel-live"
          >
            Interactive <span class="tab__hint">live</span>
          </button>
          <button
            class="tab"
            type="button"
            role="tab"
            id="tab-cine"
            aria-selected="false"
            aria-controls="panel-cine"
          >
            Cinematic finishing <span class="tab__hint">exported</span>
          </button>
          <button
            class="tab"
            type="button"
            role="tab"
            id="tab-shapes"
            aria-selected="false"
            aria-controls="panel-shapes"
          >
            Shape operators <span class="tab__hint">mograph</span>
          </button>
          <button
            class="tab"
            type="button"
            role="tab"
            id="tab-particles"
            aria-selected="false"
            aria-controls="panel-particles"
          >
            Particles <span class="tab__hint">generative</span>
          </button>
        </div>

        <section id="panel-live" class="tabpanel" role="tabpanel" aria-labelledby="tab-live">
          <p class="panel-lede">
            A <code>blur</code>, <code>bloom</code>, <code>grade</code> or <code>goo</code> prop on
            any node — rendered to a texture, processed, and composited back, live in your browser.
            Pick one to see it play, and copy the code.
          </p>
          <EffectsGallery client:only="react" />
        </section>

        <section
          id="panel-cine"
          class="tabpanel cinematic"
          role="tabpanel"
          aria-labelledby="tab-cine"
          hidden
        >
          <header class="cinematic__head">
            <p class="eyebrow">{CINEMATIC.eyebrow}</p>
            <h2 id="cinematic-title">{CINEMATIC.title}</h2>
            <p class="lede">{CINEMATIC.intro}</p>
          </header>
          <div class="cinematic__grid">
            {
              CINEMATIC.entries.map((e, i) => (
                <article class="cfx">
                  <div class="cfx__head">
                    <span class="cfx__num">{String(i + 1).padStart(2, '0')}</span>
                    <h3 class="cfx__title">{e.title}</h3>
                  </div>
                  <div class={e.strip ? 'cfx__media cfx__media--strip' : 'cfx__media'}>
                    {e.strip ? (
                      <figure class="cfx__strip">
                        <img src={e.strip} alt={e.title} loading="lazy" />
                        <figcaption>{e.stripLabel}</figcaption>
                      </figure>
                    ) : (
                      <>
                        <figure>
                          <img src={e.before.src} alt={`${e.title} before`} loading="lazy" />
                          <figcaption>{e.before.label}</figcaption>
                        </figure>
                        <figure>
                          <img src={e.after.src} alt={`${e.title} after`} loading="lazy" />
                          <figcaption>{e.after.label}</figcaption>
                        </figure>
                      </>
                    )}
                  </div>
                  <div class="cfx__detail">
                    <p class="cfx__blurb">{e.blurb}</p>
                    <pre class="cfx__code"><code>{e.snippet}</code></pre>
                  </div>
                </article>
              ))
            }
          </div>
        </section>

        <section
          id="panel-shapes"
          class="tabpanel"
          role="tabpanel"
          aria-labelledby="tab-shapes"
          hidden
        >
          <header class="cinematic__head">
            <p class="eyebrow">SHAPE OPERATORS</p>
            <h2>The mograph vocabulary — operations on the path itself.</h2>
            <p class="lede">
              Not pixels — geometry. The operators motion designers live in, all here: trim paths
              draw a stroke on; the repeater stamps a subtree into grids, radial arrays and
              compounding spirals; boolean ops merge shapes into one outline.
            </p>
          </header>
          <div class="cinematic__grid">
            <article class="cfx">
              <div class="cfx__head">
                <span class="cfx__num">01</span>
                <h3 class="cfx__title">Trim paths — the stroke line-draw</h3>
              </div>
              <div class="shapes__demo">
                <figure class="shapes__live" aria-label="A circle and checkmark drawing on, looping">
                  <svg viewBox="0 0 200 200" role="img">
                    <circle
                      class="draw"
                      cx="100"
                      cy="100"
                      r="72"
                      fill="none"
                      stroke="#e85494"
                      stroke-width="11"
                      stroke-linecap="round"
                      pathLength="100"
                    />
                    <path
                      class="draw draw--late"
                      d="M68 104 L92 132 L138 74"
                      fill="none"
                      stroke="#5ad1ff"
                      stroke-width="10"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      pathLength="100"
                    />
                  </svg>
                  <figcaption>live · animating <code>trimEnd</code> 0→1</figcaption>
                </figure>
                <figure class="shapes__strip">
                  <img
                    src="/effects/trim-progression.png"
                    alt="Trim at five stages from 0.15 to 1.0"
                    loading="lazy"
                  />
                  <figcaption>five stages — rendered by ONDA (GPU = CPU)</figcaption>
                </figure>
              </div>
              <div class="cfx__detail">
                <p class="cfx__blurb">
                  Put a <code>trimStart</code> / <code>trimEnd</code> on any stroked shape and the
                  engine draws only that arc-length slice of the outline — animate <code>trimEnd</code>
                  from 0→1 for a draw-on reveal (logos, underlines, signatures, loaders). The engine
                  measures the path length with kurbo and converts the trim to a length-normalised
                  dash, so you never touch pixel lengths; it renders identically on the GPU and the
                  CPU reference. The looping circle + check above is that same stroke-dashoffset
                  mechanism, in pure SVG; the strip is five frames rendered by the engine itself.
                </p>
                <pre class="cfx__code"><code>{`<Ellipse stroke="#e85494" strokeWidth={14} strokeCap="round"
  trimEnd={interpolate(frame, [0, 40], [0, 1],
    { extrapolateRight: "clamp" })} />`}</code></pre>
              </div>
            </article>

            <article class="cfx">
              <div class="cfx__head">
                <span class="cfx__num">02</span>
                <h3 class="cfx__title">Repeater — grids, radial arrays, spirals</h3>
              </div>
              <figure class="shapes__strip shapes__strip--solo">
                <img
                  src="/effects/repeater.png"
                  alt="A radial petal array, a compounding spiral, and a nested grid"
                  loading="lazy"
                />
                <figcaption>radial · spiral (compounding) · nested grid — one &lt;Repeater&gt; each</figcaption>
              </figure>
              <div class="cfx__detail">
                <p class="cfx__blurb">
                  Stamp a subtree <code>count</code> times, each copy COMPOUNDING one more step of
                  the transform — offset, rotation, scale — plus a step of the opacity ramp. That
                  compounding is the trick: rotation + scale don’t fan out by <code>i×</code>, they
                  wind into a real spiral (middle). Nest two and you get a grid (right); pure
                  rotation about a pivot gives a radial array (left). It’s After Effects’ shape
                  Repeater, as one component — pure composition, so it renders the same on every
                  backend, live and exported.
                </p>
                <pre class="cfx__code"><code>{`<Repeater count={26} rotation={16} scale={0.93}
  originX={180} originY={180} endOpacity={0.15}>
  <Ellipse width={40} height={40} fill="#5ad1ff" />
</Repeater>`}</code></pre>
              </div>
            </article>

            <article class="cfx">
              <div class="cfx__head">
                <span class="cfx__num">03</span>
                <h3 class="cfx__title">Boolean ops — union, difference, intersect, xor</h3>
              </div>
              <figure class="shapes__strip shapes__strip--solo">
                <img
                  src="/effects/boolean.png"
                  alt="Two circles combined four ways: union, difference, intersect, xor"
                  loading="lazy"
                />
                <figcaption>two circles, four ops — one &lt;Merge&gt; each (GPU = CPU)</figcaption>
              </figure>
              <div class="cfx__detail">
                <p class="cfx__blurb">
                  Combine shape children into ONE outline (After Effects' "Merge Paths"): union to add,
                  difference to subtract the rest from the first, intersect for the common area, xor for
                  the symmetric difference. A ring = circle − circle; a lens = circle ∩ circle; a speech
                  bubble = rect ∪ triangle. The engine flattens each operand's curves, folds them
                  pairwise with i_overlay, and rebuilds a single fillable/strokable path — resolved on
                  both backends, so GPU and CPU agree to the pixel.
                </p>
                <pre class="cfx__code"><code>{`<Merge op="difference" fill="#5ad1ff">
  <Ellipse width={130} height={130} />
  <Ellipse x={70} width={120} height={120} />
</Merge>`}</code></pre>
              </div>
            </article>
          </div>
        </section>

        <section
          id="panel-particles"
          class="tabpanel"
          role="tabpanel"
          aria-labelledby="tab-particles"
          hidden
        >
          <header class="cinematic__head">
            <p class="eyebrow">PARTICLES</p>
            <h2>A deterministic particle emitter.</h2>
            <p class="lede">
              Bursts, fountains, confetti, sparks, dust, snow. Every particle's whole state — spawn
              point, velocity, age, size, opacity, colour, spin — is a PURE function of the frame,
              the seed, and the index, so the same comp renders the same field on every machine. No
              <code>Math.random</code>, no wall-clock, no engine pass: each live particle is just a
              shape, so position, size, opacity and colour render identically on the CPU and GPU
              (only <code>spin</code> needs the GPU, like all rotation).
            </p>
          </header>
          <div class="cinematic__grid">
            <article class="cfx">
              <div class="cfx__head">
                <span class="cfx__num">01</span>
                <h3 class="cfx__title">&lt;Particles&gt; — a physics burst</h3>
              </div>
              <figure class="shapes__strip shapes__strip--solo">
                <img
                  src="/effects/particles.png"
                  alt="A colourful omnidirectional confetti burst with spinning squares and sparkles"
                  loading="lazy"
                />
                <figcaption>one frame of a 170-piece burst — deterministic, frame-driven</figcaption>
              </figure>
              <div class="cfx__detail">
                <p class="cfx__blurb">
                  Emit `count` particles from an origin (or a spawn disc), launch them along an
                  `angle` within a `spread` cone at a `speed` with variance, then let `gravity` pull
                  them through their `lifetime` while `size`, `opacity` and `colour` lerp and `spin`
                  turns them. `emitOver` staggers the emission; `loop` re-emits for a continuous
                  fountain. Because it's a closed-form function of the frame, you can scrub anywhere
                  and export deterministically — and it's frame-based, so it composes with the rest
                  of the timeline.
                </p>
                <pre class="cfx__code"><code>{`<Particles count={170} x={W/2} y={190}
  spread={360} speed={5} gravity={0.08} lifetime={70}
  shape="square" size={[13, 6]} spin={420}
  colors={["#e85494", "#ffd36b", "#5ad1ff", "#27b78d"]} />`}</code></pre>
              </div>
            </article>
          </div>
        </section>
      </main>
    </div>

    <style>
      :root { color-scheme: dark; }
      body {
        margin: 0;
        background: #0e0e12;
        color: #f2f2f4;
        font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      .gallery-page { min-height: 100vh; }
      .gnav {
        display: flex; align-items: center; gap: 24px;
        padding: 16px 32px;
        border-bottom: 1px solid #26262c;
        position: sticky; top: 0; z-index: 10;
        /* Solid bar — not a `backdrop-filter`: a backdrop blur re-blurs every video
           frame behind it and flickers the whole page under mouse movement (see
           components.astro for the full why). */
        background: rgba(14, 14, 18, 0.97);
      }
      .brand {
        display: inline-flex; align-items: center; gap: 12px;
        color: #f2f2f4; text-decoration: none;
        font-family: 'Clash Display', 'Space Grotesk', sans-serif; font-weight: 700;
        letter-spacing: 0.02em;
      }
      .brand img { display: block; height: 20px; width: auto; }
      .gnav__links { display: flex; gap: 24px; margin-left: auto; }
      .gnav__links a { color: #8e8e98; text-decoration: none; font-weight: 500; }
      .gnav__links a:hover,
      .gnav__links a[aria-current='page'] { color: #f2f2f4; }
      .gmain { max-width: 1280px; margin: 0 auto; padding: 48px 32px 96px; }
      .ghead { max-width: 64ch; margin-bottom: 40px; }
      .eyebrow {
        font-family: 'JetBrains Mono', monospace; font-size: 13px;
        letter-spacing: 0.16em; text-transform: uppercase; color: #56565f; margin: 0 0 16px;
      }
      .ghead h1 {
        font-family: 'Clash Display', 'Space Grotesk', sans-serif;
        font-size: clamp(2rem, 5vw, 3rem); font-weight: 600; line-height: 1.05;
        letter-spacing: -0.02em; margin: 0 0 16px;
      }
      .lede { color: #8e8e98; font-size: 1.125rem; margin: 0; line-height: 1.6; }
      .lede code {
        font-family: 'JetBrains Mono', monospace; font-size: 0.9em;
        color: #f2f2f4; background: #18181d; padding: 1px 6px; border-radius: 5px;
      }
      .lede strong { color: #f2f2f4; font-weight: 600; }
      /* ---------- Tabs: Interactive ↔ Cinematic finishing (segmented control) ---- */
      .tabs {
        display: inline-flex; gap: 4px; margin: 28px 0 32px;
        padding: 4px; background: #121218;
        border: 1px solid #23232a; border-radius: 13px;
      }
      .tab {
        appearance: none; border: 0; background: transparent; cursor: pointer;
        font-family: inherit; font-size: 0.95rem; font-weight: 500; color: #8e8e98;
        display: inline-flex; align-items: baseline; gap: 8px;
        padding: 9px 17px; border-radius: 9px;
        transition: background 0.16s ease, color 0.16s ease;
      }
      .tab:hover { color: #c8c8d2; }
      .tab.is-active { background: #25252e; color: #f6f6f8; }
      .tab__hint {
        font-family: 'JetBrains Mono', monospace; font-size: 10.5px;
        letter-spacing: 0.08em; text-transform: uppercase; color: #56565f;
      }
      .tab.is-active .tab__hint { color: #e85494; }
      .tab:focus-visible { outline: 2px solid #e85494; outline-offset: 2px; }
      .tabpanel[hidden] { display: none; }
      .panel-lede {
        color: #8e8e98; font-size: 1.0625rem; line-height: 1.6;
        max-width: 64ch; margin: 0 0 32px;
      }
      .panel-lede code {
        font-family: 'JetBrains Mono', monospace; font-size: 0.9em;
        color: #f2f2f4; background: #18181d; padding: 1px 6px; border-radius: 5px;
      }
      /* ---------- Cinematic finishing (exported before/after) ---------- */
      .cinematic { margin: 0; }
      .cinematic__head { max-width: 70ch; margin-bottom: 36px; }
      .cinematic__head h2 {
        font-family: 'Clash Display', 'Space Grotesk', sans-serif;
        font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 600; line-height: 1.08;
        letter-spacing: -0.02em; margin: 0 0 14px;
      }
      .cinematic__head .lede { font-size: 1.0625rem; }
      /* Each finishing move is a self-contained CARD: numbered title up top (clear
         hierarchy), the before/after media, then the blurb + code in a tidy two-up
         row. Consistent containment + rhythm instead of a ragged stacked column. */
      .cinematic__grid { display: flex; flex-direction: column; gap: 28px; }
      .cfx {
        background: linear-gradient(180deg, #131319, #0f0f15);
        border: 1px solid #23232a; border-radius: 18px;
        padding: 24px 26px 26px;
        transition: border-color 0.18s ease;
      }
      .cfx:hover { border-color: #34343d; }
      .cfx__head { display: flex; align-items: baseline; gap: 12px; margin-bottom: 18px; }
      .cfx__num {
        font-family: 'JetBrains Mono', monospace; font-size: 12px;
        letter-spacing: 0.14em; color: #e85494; flex: none;
      }
      .cfx__title {
        font-family: 'Clash Display', 'Space Grotesk', sans-serif;
        font-size: 1.3rem; font-weight: 600; letter-spacing: -0.01em; margin: 0;
      }
      .cfx__media {
        display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px;
      }
      .cfx__media--strip { grid-template-columns: 1fr; }
      .cfx figure {
        margin: 0; position: relative; border-radius: 11px; overflow: hidden;
        border: 1px solid #26262c; background: #08080c; line-height: 0;
      }
      .cfx figure img { display: block; width: 100%; height: auto; }
      .cfx figcaption {
        position: absolute; bottom: 9px; left: 10px; line-height: 1;
        font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.02em;
        color: #f2f2f4; background: rgba(0, 0, 0, 0.6); padding: 4px 9px; border-radius: 7px;
      }
      /* Blurb + snippet share a row under the media: prose left, code right, tops
         aligned — uses the width and shortens each card. */
      .cfx__detail {
        display: grid; grid-template-columns: minmax(0, 1.35fr) minmax(0, 1fr);
        gap: 24px; align-items: start;
      }
      .cfx__blurb { color: #9a9aa4; line-height: 1.6; font-size: 0.95rem; margin: 0; }
      .cfx__code {
        background: #08080c; border: 1px solid #23232a; border-radius: 10px;
        padding: 13px 15px; overflow-x: auto; margin: 0;
      }
      .cfx__code code {
        font-family: 'JetBrains Mono', monospace; font-size: 12.5px; line-height: 1.5;
        color: #cdd2e0; white-space: pre;
      }
      /* ---------- Shape operators: a live SVG draw-on + the engine strip ---------- */
      .shapes__demo {
        display: grid; grid-template-columns: 0.78fr 1.22fr; gap: 14px;
        align-items: stretch; margin-bottom: 20px;
      }
      .shapes__live, .shapes__strip {
        margin: 0; position: relative; border-radius: 11px; overflow: hidden;
        border: 1px solid #26262c; background: #0a0d17; line-height: 0;
      }
      .shapes__live { display: flex; align-items: center; justify-content: center; padding: 18px; }
      .shapes__live svg { width: 78%; max-width: 230px; height: auto; display: block; }
      .shapes__strip { display: flex; align-items: center; }
      .shapes__strip--solo { margin-bottom: 20px; }
      .shapes__strip img { display: block; width: 100%; height: auto; }
      .shapes__live figcaption, .shapes__strip figcaption {
        position: absolute; bottom: 9px; left: 10px; line-height: 1;
        font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.02em;
        color: #f2f2f4; background: rgba(0, 0, 0, 0.6); padding: 4px 9px; border-radius: 7px;
      }
      .shapes__live figcaption code, .cfx figcaption code {
        font-family: inherit; color: #e85494; background: none; padding: 0;
      }
      /* The line-draw: `pathLength=100` normalises every path, so one keyframe draws on
         (offset 100→0), holds, then erases off (→ -100) for a seamless loop. This IS
         trim's length-normalised dash, in CSS. */
      .draw { stroke-dasharray: 100; animation: trimDraw 3.4s ease-in-out infinite; }
      .draw--late { animation-delay: 0.55s; }
      @keyframes trimDraw {
        0% { stroke-dashoffset: 100; }
        42% { stroke-dashoffset: 0; }
        68% { stroke-dashoffset: 0; }
        100% { stroke-dashoffset: -100; }
      }
      @media (prefers-reduced-motion: reduce) {
        .draw { animation: none; stroke-dashoffset: 0; }
      }
      @media (max-width: 760px) {
        .shapes__demo { grid-template-columns: 1fr; }
      }
      @media (max-width: 860px) {
        .cfx__detail { grid-template-columns: 1fr; gap: 16px; }
      }
      @media (max-width: 760px) {
        .gnav__links { display: none; }
        .gmain { padding: 32px 20px 64px; }
        .cfx { padding: 18px 18px 20px; }
        .cfx__media { grid-template-columns: 1fr; }
      }
    </style>

    <script>
      // Tab switcher: toggle VISIBILITY (never unmount) so the live WebGPU gallery
      // keeps its engine across switches. Deep-linkable via the hash + arrow-key nav.
      const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.tab'))
      const panelFor = (tabId: string) => document.getElementById(tabId.replace('tab-', 'panel-'))
      const HASH: Record<string, string> = {
        interactive: 'tab-live',
        live: 'tab-live',
        cinematic: 'tab-cine',
        finishing: 'tab-cine',
        cine: 'tab-cine',
        shapes: 'tab-shapes',
        'shape-operators': 'tab-shapes',
        mograph: 'tab-shapes',
        particles: 'tab-particles',
        generative: 'tab-particles',
      }

      function activate(tabId: string, opts: { focus?: boolean; push?: boolean } = {}) {
        for (const t of tabs) {
          const on = t.id === tabId
          t.classList.toggle('is-active', on)
          t.setAttribute('aria-selected', on ? 'true' : 'false')
          t.tabIndex = on ? 0 : -1
          const panel = panelFor(t.id)
          if (panel) panel.hidden = !on
          if (on && opts.focus) t.focus()
        }
        if (opts.push !== false) {
          const slug =
            tabId === 'tab-cine'
              ? 'cinematic'
              : tabId === 'tab-shapes'
                ? 'shapes'
                : tabId === 'tab-particles'
                  ? 'particles'
                  : 'interactive'
          history.replaceState(null, '', `#${slug}`)
        }
      }

      for (const t of tabs) t.addEventListener('click', () => activate(t.id))

      // ← / → move between tabs (WAI-ARIA tabs pattern).
      document.querySelector('.tabs')?.addEventListener('keydown', (e) => {
        const ev = e as KeyboardEvent
        if (ev.key !== 'ArrowRight' && ev.key !== 'ArrowLeft') return
        const i = tabs.findIndex((t) => t.classList.contains('is-active'))
        const n = ev.key === 'ArrowRight' ? (i + 1) % tabs.length : (i - 1 + tabs.length) % tabs.length
        activate(tabs[n].id, { focus: true })
        ev.preventDefault()
      })

      // Deep link: /effects#cinematic (or #finishing) opens that tab on load.
      const fromHash = HASH[(location.hash || '').replace('#', '').toLowerCase()]
      if (fromHash) activate(fromHash, { push: false })
    </script>
  </body>
</html>
