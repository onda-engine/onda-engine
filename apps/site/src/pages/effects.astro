---
// The ONDA effects showcase — the render-to-texture node effects (blur, bloom,
// grade, goo), each played live by the engine (Vello/WebGPU, CPU fallback).
// Standalone page (not a Starlight doc) so the player can use a full-width layout.
import EffectsGallery from '../components/EffectsGallery.tsx'
const REPO = 'https://github.com/degueba/onda-engine'

// Cinematic finishing — the export/native premium moves whose before/after is a
// rendered still (the live preview degrades them). Update this list when a new
// export-only effect ships (with a before/after + an accurate blurb).
const CINEMATIC = {
  eyebrow: 'CINEMATIC FINISHING',
  title: 'The finishing pass — exported, native, premium-tier.',
  intro:
    'These are the export/native finishing moves — the difference lives in the GPU compute pass, so the live page degrades them (fBm falls back to a smooth gradient, the linear + ACES path falls back to gamma) and each before/after is an exported still. The one exception is morphPath: pure authoring, zero engine change, so it plays live.',
  entries: [
    {
      title: 'fBm gradient',
      blurb:
        'Left, a flat 2-stop linear ramp. Right, the SAME stops as an fBm gradient — the soft, flowing Stripe/Linear-tier surface that reads "expensive," the tell that a backdrop was art-directed, not just filled. Fractal Brownian motion over 2D Simplex noise plus a domain-warp, run as a GPU compute pass; animate time for a living surface.',
      snippet:
        '<Rect width={W} height={H} fill={fbmGradient(stops, { scale: 1, warp: 0.5, time: frame / fps })} />',
      before: { src: '/effects/fbm-before.png', label: 'flat linear' },
      after: { src: '/effects/fbm-after.png', label: 'fBm' },
    },
    {
      title: 'Linear + ACES cinematic finish',
      blurb:
        'Same bloomed plate, left and right — but on the right the glow is real light bleed, not a flat overlay, the tell that separates "rendered" from "shot." Flip the linear flag on the Composition: Bloom composites in linear light, then an ACES filmic tone-map rolls the highlights off in a smooth curve instead of the default gamma additive-clamp.',
      snippet: `<Composition linear width={1920} height={1080}>
  <Group bloom={{ sigma: 16, intensity: 1.7 }}>
    <Img src="plate.jpg" />
  </Group>
</Composition>`,
      before: { src: '/effects/linear-before.png', label: 'gamma clamp' },
      after: { src: '/effects/linear-after.png', label: 'linear + ACES' },
    },
    {
      title: 'morphPath',
      blurb:
        'A circle continuously morphing into a rule — one element transforming into another, the Apple/ElevenLabs "magic move" that reads as a single object, not a crossfade. morphPath(from, to, t) returns the in-between path for an animated t; flubber solves the hard part — point CORRESPONDENCE between the two outlines (a naive d-string lerp tears shapes apart). Zero engine change, so it plays live.',
      snippet: '<Path d={morphPath(CIRCLE, RULE, ramp(frame, 70, 95))} fill="#fff" />',
      strip: '/effects/morph-strip.png',
      stripLabel: 'circle → rule, five stages of one morph',
    },
  ],
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Effects — ONDA</title>
    <meta
      name="description"
      content="Render-to-texture effects — blur, bloom, color grade, gooey morph — applied to any node and played live in your browser by the ONDA GPU engine."
    />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0e0e12" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=clash-display@600,700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="gallery-page">
      <header class="gnav">
        <a class="brand" href="/" aria-label="ONDA — home">
          <img src="/onda-mark.svg" alt="" width="80" height="20" />
          <span>ONDA</span>
        </a>
        <nav class="gnav__links" aria-label="Primary">
          <a href="/">Home</a>
          <a href="/components">Components</a>
          <a href="/transitions">Transitions</a>
          <a href="/effects" aria-current="page">Effects</a>
          <a href="/guide/introduction">Docs</a>
          <a href={REPO} rel="noopener">GitHub</a>
        </nav>
      </header>

      <main class="gmain">
        <header class="ghead">
          <p class="eyebrow">Render-to-texture</p>
          <h1>Effects, rendered by the engine.</h1>
          <p class="lede">
            A <code>blur</code>, <code>bloom</code>, <code>grade</code> or <code>goo</code> prop on
            any node — rendered to a texture, processed, and composited back, live in your browser by
            the GPU engine. Pick one to see it play — and copy the code.
          </p>
        </header>
        <EffectsGallery client:only="react" />

        <section class="cinematic" aria-labelledby="cinematic-title">
          <header class="cinematic__head">
            <p class="eyebrow">{CINEMATIC.eyebrow}</p>
            <h2 id="cinematic-title">{CINEMATIC.title}</h2>
            <p class="lede">{CINEMATIC.intro}</p>
          </header>
          <div class="cinematic__grid">
            {
              CINEMATIC.entries.map((e) => (
                <article class="cfx">
                  <div class={e.strip ? 'cfx__media cfx__media--strip' : 'cfx__media'}>
                    {e.strip ? (
                      <figure class="cfx__strip">
                        <img src={e.strip} alt={e.title} loading="lazy" />
                        <figcaption>{e.stripLabel}</figcaption>
                      </figure>
                    ) : (
                      <>
                        <figure>
                          <img src={e.before.src} alt={`${e.title} before`} loading="lazy" />
                          <figcaption>{e.before.label}</figcaption>
                        </figure>
                        <figure>
                          <img src={e.after.src} alt={`${e.title} after`} loading="lazy" />
                          <figcaption>{e.after.label}</figcaption>
                        </figure>
                      </>
                    )}
                  </div>
                  <h3 class="cfx__title">{e.title}</h3>
                  <p class="cfx__blurb">{e.blurb}</p>
                  <pre class="cfx__code"><code>{e.snippet}</code></pre>
                </article>
              ))
            }
          </div>
        </section>
      </main>
    </div>

    <style>
      :root { color-scheme: dark; }
      body {
        margin: 0;
        background: #0e0e12;
        color: #f2f2f4;
        font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      .gallery-page { min-height: 100vh; }
      .gnav {
        display: flex; align-items: center; gap: 24px;
        padding: 16px 32px;
        border-bottom: 1px solid #26262c;
        position: sticky; top: 0; z-index: 10;
        background: rgba(14, 14, 18, 0.82);
        backdrop-filter: saturate(120%) blur(12px);
      }
      .brand {
        display: inline-flex; align-items: center; gap: 12px;
        color: #f2f2f4; text-decoration: none;
        font-family: 'Clash Display', 'Space Grotesk', sans-serif; font-weight: 700;
        letter-spacing: 0.02em;
      }
      .brand img { display: block; height: 20px; width: auto; }
      .gnav__links { display: flex; gap: 24px; margin-left: auto; }
      .gnav__links a { color: #8e8e98; text-decoration: none; font-weight: 500; }
      .gnav__links a:hover,
      .gnav__links a[aria-current='page'] { color: #f2f2f4; }
      .gmain { max-width: 1280px; margin: 0 auto; padding: 48px 32px 96px; }
      .ghead { max-width: 64ch; margin-bottom: 40px; }
      .eyebrow {
        font-family: 'JetBrains Mono', monospace; font-size: 13px;
        letter-spacing: 0.16em; text-transform: uppercase; color: #56565f; margin: 0 0 16px;
      }
      .ghead h1 {
        font-family: 'Clash Display', 'Space Grotesk', sans-serif;
        font-size: clamp(2rem, 5vw, 3rem); font-weight: 600; line-height: 1.05;
        letter-spacing: -0.02em; margin: 0 0 16px;
      }
      .lede { color: #8e8e98; font-size: 1.125rem; margin: 0; line-height: 1.6; }
      .lede code {
        font-family: 'JetBrains Mono', monospace; font-size: 0.9em;
        color: #f2f2f4; background: #18181d; padding: 1px 6px; border-radius: 5px;
      }
      /* ---------- Cinematic finishing (exported before/after) ---------- */
      .cinematic { margin-top: 88px; padding-top: 56px; border-top: 1px solid #26262c; }
      .cinematic__head { max-width: 70ch; margin-bottom: 40px; }
      .cinematic__head h2 {
        font-family: 'Clash Display', 'Space Grotesk', sans-serif;
        font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 600; line-height: 1.08;
        letter-spacing: -0.02em; margin: 0 0 14px;
      }
      .cinematic__head .lede { font-size: 1.0625rem; }
      .cinematic__grid { display: flex; flex-direction: column; gap: 64px; }
      .cfx__media {
        display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
      }
      .cfx__media--strip { grid-template-columns: 1fr; }
      .cfx figure {
        margin: 0; position: relative; border-radius: 12px; overflow: hidden;
        border: 1px solid #26262c; background: #08080c; line-height: 0;
      }
      .cfx figure img { display: block; width: 100%; height: auto; }
      .cfx figcaption {
        position: absolute; bottom: 10px; left: 12px; line-height: 1;
        font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 0.02em;
        color: #f2f2f4; background: rgba(0, 0, 0, 0.58); padding: 4px 9px; border-radius: 7px;
      }
      .cfx__title {
        font-family: 'Clash Display', 'Space Grotesk', sans-serif;
        font-size: 1.4rem; font-weight: 600; letter-spacing: -0.01em; margin: 22px 0 8px;
      }
      .cfx__blurb { color: #8e8e98; line-height: 1.6; max-width: 72ch; margin: 0 0 16px; }
      .cfx__code {
        background: #08080c; border: 1px solid #26262c; border-radius: 10px;
        padding: 14px 16px; overflow-x: auto; margin: 0;
      }
      .cfx__code code {
        font-family: 'JetBrains Mono', monospace; font-size: 13px; line-height: 1.5;
        color: #cdd2e0; white-space: pre;
      }
      @media (max-width: 760px) {
        .gnav__links { display: none; }
        .gmain { padding: 32px 20px 64px; }
        .cfx__media { grid-template-columns: 1fr; }
      }
    </style>
  </body>
</html>
