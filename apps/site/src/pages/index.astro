        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        overflow-x: hidden;
      }
      .onda-landing *,
      .onda-landing *::before,
      .onda-landing *::after {
        box-sizing: border-box;
      }
      .onda-landing img,
      .onda-landing svg {
        display: block;
        max-width: 100%;
      }
      .onda-landing h1,
      .onda-landing h2,
      .onda-landing h3 {
        font-family: var(--font-head);
        line-height: 1.02;
        margin: 0;
        letter-spacing: -0.015em;
        font-weight: 600;
      }
      .onda-landing p {
        margin: 0;
      }
      .onda-landing a {
        color: var(--accent);
        text-decoration: none;
        transition: color var(--dur) var(--ease);
      }
      .onda-landing a:hover {
        color: var(--accent-600);
      }
      .onda-landing code {
        font-family: var(--font-code);
        font-size: 0.92em;
      }
      .onda-landing strong {
        color: var(--text);
        font-weight: 600;
      }
      .onda-landing em {
        font-style: italic;
        color: var(--text);
      }
      .onda-landing :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
        border-radius: 4px;
      }

      .skip-link {
        position: absolute;
        left: var(--s-4);
        top: -120%;
        z-index: 200;
        background: var(--accent);
        color: var(--on-accent);
        padding: var(--s-3) var(--s-4);
        border-radius: var(--r-control);
        font-weight: 600;
        transition: top var(--dur) var(--ease);
      }
      .skip-link:focus {
        top: var(--s-4);
        color: var(--on-accent);
      }

      .container {
        width: 100%;
        max-width: var(--maxw);
        margin-inline: auto;
        padding-inline: var(--s-6);
      }
      .section {
        padding-block: var(--s-32);
      }
      .section--alt {
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
      }
      .section__head {
        max-width: 60ch;
        margin-bottom: var(--s-16);
      }
      .section__title {
        font-size: var(--fs-3xl);
        font-weight: 600;
        margin-bottom: var(--s-6);
      }
      .section__lede {
        font-size: var(--fs-md);
        color: var(--text-muted);
      }
      .eyebrow {
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--text-dim);
        margin-bottom: var(--s-6);
      }
      .accent-text {
        color: var(--accent);
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: var(--s-2);
        min-height: 44px;
        padding: 0 var(--s-6);
        border-radius: var(--r-control);
        font-family: var(--font-body);
        font-weight: 600;
        font-size: var(--fs-base);
        border: 1px solid transparent;
        cursor: pointer;
        transition: background var(--dur) var(--ease), border-color var(--dur) var(--ease),
          transform var(--dur) var(--ease), color var(--dur) var(--ease);
        white-space: nowrap;
      }
      .btn:active {
        transform: translateY(1px);
      }
      /* Prefixed with .onda-landing so the button text color outranks the
         scoped base `.onda-landing a` rule (these buttons are <a> elements). */
      .onda-landing .btn--primary {
        background: var(--accent);
        color: var(--on-accent);
      }
      .onda-landing .btn--primary:hover {
        background: var(--accent-600);
        color: var(--on-accent);
      }
      .onda-landing .btn--ghost {
        background: transparent;
        color: var(--text);
        border-color: var(--border);
      }
      .onda-landing .btn--ghost:hover {
        background: var(--surface-2);
        color: var(--text);
        border-color: #34343c;
      }
      .btn--lg {
        min-height: 52px;
        padding: 0 var(--s-8);
        font-size: var(--fs-md);
      }
      .btn__icon {
        flex: none;
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(14, 14, 18, 0.72);
        backdrop-filter: saturate(120%) blur(12px);
        -webkit-backdrop-filter: saturate(120%) blur(12px);
        border-bottom: 1px solid transparent;
        transition: border-color var(--dur) var(--ease), background var(--dur) var(--ease);
      }
      .nav.is-scrolled {
        border-bottom-color: var(--border);
        background: rgba(14, 14, 18, 0.9);
      }
      .nav__inner {
        display: flex;
        align-items: center;
        gap: var(--s-6);
        min-height: 64px;
      }
      .onda-landing .brand {
        display: inline-flex;
        align-items: center;
        gap: var(--s-3);
        color: var(--text);
        font-family: var(--font-head);
      }
      .onda-landing .brand:hover {
        color: var(--text);
      }
      .brand__mark-img {
        height: 22px;
        width: auto;
      }
      .brand__word {
        font-weight: 700;
        font-size: var(--fs-lg);
        letter-spacing: 0.02em;
      }
      .nav__links {
        display: flex;
        gap: var(--s-6);
        margin-left: auto;
      }
      .nav__links a {
        color: var(--text-muted);
        font-weight: 500;
        padding: var(--s-2) 0;
      }
      .nav__links a:hover {
        color: var(--text);
      }
      .nav__cta {
        margin-left: var(--s-2);
      }

      .hero {
        position: relative;
        padding-block: var(--s-32) var(--s-32);
        overflow: hidden;
      }
      .hero__bg {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
      }
      .hero__wash {
        position: absolute;
        inset: 0;
        background: radial-gradient(60% 70% at 88% 0%, var(--accent-soft), transparent 60%);
      }
      .hero__grid {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1.05fr 1fr;
        gap: var(--s-16);
        align-items: center;
      }
      .hero__mark {
        height: 54px;
        width: auto;
        margin-bottom: var(--s-6);
      }
      .hero__title {
        font-size: clamp(3rem, 7.5vw, var(--fs-5xl));
        font-weight: 700;
        line-height: 0.98;
        letter-spacing: -0.025em;
        margin-bottom: var(--s-8);
      }
      .hero__sub {
        font-size: var(--fs-lg);
        color: var(--text-muted);
        max-width: 52ch;
        margin-bottom: var(--s-8);
      }
      .hero__actions {
        display: flex;
        flex-wrap: wrap;
        gap: var(--s-4);
        margin-bottom: var(--s-8);
      }
      .hero__chips {
        display: flex;
        flex-wrap: wrap;
        gap: var(--s-2);
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .hero__chips li {
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        color: var(--text-muted);
        border: 1px solid var(--border);
        border-radius: var(--r-pill);
        padding: var(--s-2) var(--s-4);
      }

      .code-card {
        margin: 0;
        background: var(--bg-deep);
        border: 1px solid var(--border);
        border-radius: var(--r-card);
        box-shadow: var(--elev-card);
        overflow: hidden;
      }
      .code-card__bar {
        display: flex;
        align-items: center;
        gap: var(--s-3);
        padding: var(--s-3) var(--s-4);
        background: var(--surface);
        border-bottom: 1px solid var(--border);
      }
      .code-card__dots {
        display: inline-flex;
        gap: 6px;
      }
      .code-card__dots i {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        background: var(--surface-2);
        border: 1px solid var(--border);
      }
      .code-card__file {
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        color: var(--text-muted);
      }
      .code-card__copy {
        margin-left: auto;
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-muted);
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        padding: var(--s-1) var(--s-3);
        border-radius: var(--r-control);
        min-height: 32px;
        cursor: pointer;
        transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease),
          background var(--dur) var(--ease);
      }
      .code-card__copy:hover {
        color: var(--text);
        border-color: #34343c;
        background: var(--surface-2);
      }
      .code-card__copy.is-copied {
        color: var(--accent);
        border-color: var(--accent);
      }
      .code-card__pre {
        margin: 0;
        padding: var(--s-6);
        overflow-x: auto;
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        line-height: 1.7;
        tab-size: 2;
      }
      .code-card__pre code {
        color: var(--text);
        white-space: pre;
        font-family: var(--font-code);
      }
      .tok-kw {
        color: var(--accent);
      }
      .tok-tag {
        color: var(--text);
        font-weight: 500;
      }
      .tok-attr {
        color: var(--text-muted);
      }
      .tok-str {
        color: #b8b8c0;
      }
      .tok-num {
        color: var(--text);
      }
      .tok-fn {
        color: var(--accent);
      }
      .tok-comment {
        color: var(--text-dim);
        font-style: italic;
      }

      .arch {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: var(--s-12);
        align-items: stretch;
      }
      .arch__col {
        border: 1px solid var(--border);
        border-radius: var(--r-card);
        padding: var(--s-8);
      }
      .arch__col--onda {
        border-color: rgba(217, 107, 130, 0.45);
      }
      .arch__name {
        font-size: var(--fs-xl);
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: var(--s-3);
        margin-bottom: var(--s-8);
      }
      .arch__tag {
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        font-weight: 500;
        padding: 2px var(--s-3);
        border-radius: var(--r-pill);
      }
      .arch__tag--muted {
        color: var(--text-muted);
        border: 1px solid var(--border);
      }
      .arch__tag--brand {
        background: var(--accent-soft);
        color: var(--accent);
        border: 1px solid rgba(217, 107, 130, 0.4);
      }
      .flow {
        list-style: none;
        margin: 0 0 var(--s-6);
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--s-3);
      }
      .flow__node {
        position: relative;
        border: 1px solid var(--border);
        border-radius: var(--r-control);
        padding: var(--s-3) var(--s-4);
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        color: var(--text-muted);
      }
      .flow__node + .flow__node::before {
        content: '';
        position: absolute;
        top: calc(-1 * var(--s-3) - 1px);
        left: 50%;
        width: 1px;
        height: var(--s-3);
        background: var(--border);
      }
      .flow__node--warn {
        color: var(--text-dim);
        border-style: dashed;
      }
      .flow__node--ok {
        color: var(--text);
      }
      .flow__node--end {
        background: var(--accent-soft);
        border-color: rgba(217, 107, 130, 0.4);
        color: var(--text);
        font-weight: 600;
      }
      .arch__note {
        color: var(--text-muted);
        font-size: var(--fs-sm);
      }
      .arch__vs {
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .arch__vs span {
        font-family: var(--font-code);
        font-weight: 500;
        font-size: var(--fs-sm);
        color: var(--text-dim);
        border: 1px solid var(--border);
        border-radius: var(--r-pill);
        width: 44px;
        height: 44px;
        display: grid;
        place-items: center;
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        border-top: 1px solid var(--border);
      }
      .stat {
        padding: var(--s-12) var(--s-8) var(--s-8);
        border-bottom: 1px solid var(--border);
        border-right: 1px solid var(--border);
      }
      .stat:first-child {
        border-left: 1px solid var(--border);
      }
      .stat__num {
        font-family: var(--font-head);
        font-weight: 700;
        font-size: var(--fs-4xl);
        line-height: 1;
        letter-spacing: -0.02em;
        margin-bottom: var(--s-4);
      }
      .stat__label {
        font-size: var(--fs-md);
        font-weight: 600;
        margin-bottom: var(--s-1);
      }
      .stat__sub {
        color: var(--text-muted);
        font-size: var(--fs-sm);
      }
      .stats__foot {
        margin-top: var(--s-8);
        color: var(--text-muted);
        font-size: var(--fs-sm);
        max-width: 70ch;
      }

      .features {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--s-8) var(--s-12);
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .feature {
        padding-top: var(--s-8);
        border-top: 1px solid var(--border);
        transition: border-color var(--dur) var(--ease);
      }
      .feature:hover {
        border-top-color: var(--accent);
      }
      .feature__icon {
        display: inline-grid;
        place-items: center;
        width: 40px;
        height: 40px;
        border-radius: var(--r-control);
        border: 1px solid var(--border);
        color: var(--accent);
        margin-bottom: var(--s-6);
      }
      .feature__title {
        font-size: var(--fs-lg);
        font-weight: 600;
        margin-bottom: var(--s-3);
      }
      .feature__body {
        color: var(--text-muted);
      }
      .feature__body code {
        color: var(--text);
        background: var(--surface-2);
        padding: 1px 5px;
        border-radius: 5px;
      }
      .features__note {
        margin-top: var(--s-16);
        text-align: center;
        color: var(--text-muted);
      }

      .story {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: var(--s-12);
        align-items: center;
      }
      .story__arrow {
        display: grid;
        place-items: center;
        color: var(--text-dim);
      }
      .story__result {
        margin: 0;
      }
      .preview {
        position: relative;
        aspect-ratio: 16 / 9;
        width: 100%;
        border-radius: var(--r-card);
        border: 1px solid var(--border);
        background: var(--bg-deep);
        overflow: hidden;
        display: grid;
        place-content: center;
        box-shadow: var(--elev-card);
      }
      .preview__badge {
        position: absolute;
        top: var(--s-3);
        right: var(--s-3);
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        color: var(--text-muted);
        background: rgba(8, 8, 10, 0.7);
        border: 1px solid var(--border);
        border-radius: var(--r-pill);
        padding: 2px var(--s-3);
      }
      .preview__text {
        font-family: var(--font-head);
        font-weight: 700;
        font-size: clamp(2rem, 6vw, 3.4rem);
        letter-spacing: -0.02em;
        color: var(--text);
      }
      .preview__bar {
        position: absolute;
        left: 12%;
        right: 12%;
        bottom: 16%;
        height: 6px;
        border-radius: var(--r-pill);
        background: var(--accent);
      }
      .story__caption {
        margin-top: var(--s-4);
        color: var(--text-muted);
        font-size: var(--fs-sm);
      }

      .cta {
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        padding-block: var(--s-32);
      }
      .cta__inner {
        text-align: center;
        max-width: 60ch;
        margin-inline: auto;
      }
      .cta__title {
        font-size: var(--fs-3xl);
        font-weight: 600;
        margin-bottom: var(--s-6);
      }
      .cta__sub {
        color: var(--text-muted);
        font-size: var(--fs-md);
        margin-bottom: var(--s-8);
      }

      .footer {
        padding-top: var(--s-20);
      }
      .footer__inner {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: var(--s-8);
        padding-bottom: var(--s-16);
      }
      .footer__tag {
        color: var(--text-muted);
        margin-top: var(--s-4);
        max-width: 38ch;
      }
      .footer__nav {
        display: flex;
        flex-direction: column;
        gap: var(--s-3);
      }
      .footer__col-title {
        font-family: var(--font-head);
        font-size: var(--fs-base);
        font-weight: 600;
        color: var(--text);
        margin-bottom: var(--s-1);
      }
      .footer__nav a {
        color: var(--text-muted);
        font-weight: 500;
      }
      .footer__nav a:hover {
        color: var(--text);
      }
      .footer__bottom {
        display: flex;
        flex-wrap: wrap;
        gap: var(--s-4);
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid var(--border);
        padding-block: var(--s-6) var(--s-12);
        color: var(--text-muted);
        font-size: var(--fs-sm);
      }
      .footer__bottom a {
        color: var(--text-muted);
        font-family: var(--font-code);
      }
      .footer__bottom a:hover {
        color: var(--accent);
      }

      .reveal {
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 500ms var(--ease), transform 500ms var(--ease);
        will-change: opacity, transform;
      }
      .reveal.is-visible {
        opacity: 1;
        transform: none;
      }

      @media (max-width: 1024px) {
        .hero__grid {
          grid-template-columns: 1fr;
          gap: var(--s-12);
        }
        .features {
          grid-template-columns: repeat(2, 1fr);
        }
        .footer__inner {
          grid-template-columns: 1fr 1fr;
        }
        .footer__brand {
          grid-column: 1 / -1;
        }
      }
      @media (max-width: 768px) {
        .section {
          padding-block: var(--s-20);
        }
        .hero {
          padding-block: var(--s-20);
        }
        .section__title,
        .cta__title {
          font-size: var(--fs-2xl);
        }
        .arch {
          grid-template-columns: 1fr;
          gap: var(--s-8);
        }
        .arch__vs {
          padding: var(--s-2) 0;
        }
        .stats {
          grid-template-columns: 1fr;
          border: 1px solid var(--border);
          border-bottom: 0;
        }
        .stat {
          border-right: 0;
          border-left: 0;
        }
        .stat:first-child {
          border-left: 0;
        }
        .story {
          grid-template-columns: 1fr;
          gap: var(--s-8);
        }
        .story__arrow {
          transform: rotate(90deg);
        }
        .nav__links {
          display: none;
        }
      }
      @media (max-width: 480px) {
        .container {
          padding-inline: var(--s-4);
        }
        .features {
          grid-template-columns: 1fr;
        }
        .footer__inner {
          grid-template-columns: 1fr;
        }
        .nav__cta {
          padding: 0 var(--s-4);
        }
        .code-card__pre {
          font-size: 0.8rem;
          padding: var(--s-4);
        }
      }
      @media (prefers-reduced-motion: reduce) {
        .reveal {
          opacity: 1;
          transform: none;
          transition: none;
        }
      }
    </style>
  </body>
</html>
