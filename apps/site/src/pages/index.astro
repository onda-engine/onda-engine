        font-weight: 600;
        box-shadow: 0 0 0 1px rgba(176, 108, 255, 0.45), 0 6px 22px -6px var(--studio-glow);
        transition: transform var(--dur) var(--ease), box-shadow var(--dur) var(--ease),
          color var(--dur) var(--ease);
      }
      .onda-landing .nav__links a.nav__studio-link:hover {
        color: var(--on-studio);
        transform: translateY(-1px) scale(1.03);
        box-shadow: 0 0 0 1px var(--studio), 0 12px 30px -6px var(--studio-glow);
      }
      .nav__studio-spark {
        width: 13px;
        height: 13px;
        flex: none;
      }
      /* Mobile menu toggle — hidden until the links collapse (≤768px). */
      .nav__toggle {
        display: none;
        width: 44px;
        height: 44px;
        align-items: center;
        justify-content: center;
        flex: none;
        background: transparent;
        border: 1px solid var(--border);
        border-radius: var(--r-control);
        color: var(--text);
        cursor: pointer;
      }
      .nav__toggle:hover {
        background: var(--surface-2);
        border-color: #34343c;
      }
      /* Prefixed with .onda-landing so it outranks the `.onda-landing svg`
         reset (display:block) — otherwise the X shows alongside the bars. */
      .onda-landing .nav__toggle-x {
        display: none;
      }
      .nav.is-open .nav__toggle-bars {
        display: none;
      }
      .nav.is-open .nav__toggle-x {
        display: block;
      }

      .hero {
        position: relative;
        padding-block: var(--s-20) var(--s-32);
        overflow: hidden;
      }
      .hero__bg {
        position: absolute;
        inset: -20% 0 0;
        z-index: 0;
        pointer-events: none;
      }
      .hero__wash {
        position: absolute;
        inset: 0;
        background: radial-gradient(60% 70% at 88% 0%, var(--accent-soft), transparent 60%);
        will-change: transform, opacity;
      }
      .hero__mark {
        height: 54px;
        width: auto;
        margin-bottom: var(--s-6);
      }
      .hero__title {
        font-size: clamp(3rem, 7.5vw, var(--fs-5xl));
        font-weight: 700;
        line-height: 0.98;
        letter-spacing: -0.025em;
        margin-bottom: var(--s-8);
      }
      .hero__sub {
        font-size: var(--fs-lg);
        color: var(--text-muted);
        max-width: 52ch;
        margin-bottom: var(--s-8);
      }
      .hero__actions {
        display: flex;
        flex-wrap: wrap;
        gap: var(--s-4);
        margin-bottom: var(--s-8);
      }
      .hero__chips {
        display: flex;
        flex-wrap: wrap;
        gap: var(--s-2);
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .hero__chips li {
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        color: var(--text-muted);
        border: 1px solid var(--border);
        border-radius: var(--r-pill);
        padding: var(--s-2) var(--s-4);
      }
      /* A thin "keep scrolling" cue under the hero. */
      .hero__scroll {
        position: absolute;
        left: 50%;
        bottom: var(--s-8);
        transform: translateX(-50%);
        z-index: 1;
        display: block;
      }
      .hero__scroll-line {
        display: block;
        width: 1px;
        height: 46px;
        background: linear-gradient(var(--accent), transparent);
        overflow: hidden;
      }

      .code-card {
        margin: 0;
        background: var(--bg-deep);
        border: 1px solid var(--border);
        border-radius: var(--r-card);
        box-shadow: var(--elev-card);
        overflow: hidden;
      }
      .code-card__bar {
        display: flex;
        align-items: center;
        gap: var(--s-3);
        padding: var(--s-3) var(--s-4);
        background: var(--surface);
        border-bottom: 1px solid var(--border);
      }
      .code-card__dots {
        display: inline-flex;
        gap: 6px;
      }
      .code-card__dots i {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        background: var(--surface-2);
        border: 1px solid var(--border);
      }
      .code-card__file {
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        color: var(--text-muted);
      }
      .code-card__copy {
        margin-left: auto;
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-muted);
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        padding: var(--s-1) var(--s-3);
        border-radius: var(--r-control);
        min-height: 32px;
        cursor: pointer;
        transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease),
          background var(--dur) var(--ease);
      }
      .code-card__copy:hover {
        color: var(--text);
        border-color: #34343c;
        background: var(--surface-2);
      }
      .code-card__copy.is-copied {
        color: var(--accent);
        border-color: var(--accent);
      }
      .code-card__pre {
        margin: 0;
        padding: var(--s-6);
        overflow-x: auto;
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        line-height: 1.7;
        tab-size: 2;
      }
      .code-card__pre code {
        color: var(--text);
        white-space: pre;
        font-family: var(--font-code);
      }
      .tok-kw {
        color: var(--accent);
      }
      .tok-tag {
        color: var(--text);
        font-weight: 500;
      }
      .tok-attr {
        color: var(--text-muted);
      }
      .tok-str {
        color: #b8b8c0;
      }
      .tok-num {
        color: var(--text);
      }
      .tok-fn {
        color: var(--accent);
      }
      .tok-comment {
        color: var(--text-dim);
        font-style: italic;
      }

      .arch {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: var(--s-12);
        align-items: stretch;
      }
      .arch__col {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--r-card);
        padding: var(--s-12);
        transition: transform var(--dur) var(--ease), border-color var(--dur) var(--ease);
      }
      .arch__col:hover {
        transform: translateY(-2px);
      }
      .arch__col--onda {
        border-color: rgba(217, 107, 130, 0.45);
        position: relative;
        box-shadow: 0 10px 50px -18px rgba(217, 107, 130, 0.35);
      }
      .arch__name {
        font-size: var(--fs-xl);
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: var(--s-3);
        margin-bottom: var(--s-12);
      }
      .arch__tag {
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        font-weight: 500;
        padding: 2px var(--s-3);
        border-radius: var(--r-pill);
      }
      .arch__tag--muted {
        color: var(--text-muted);
        border: 1px solid var(--border);
      }
      .arch__tag--brand {
        background: var(--accent-soft);
        color: var(--accent);
        border: 1px solid rgba(217, 107, 130, 0.4);
      }
      .flow {
        list-style: none;
        margin: 0 0 var(--s-8);
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--s-3);
      }
      .flow__node {
        position: relative;
        border: 1px solid var(--border);
        border-radius: var(--r-control);
        padding: var(--s-3) var(--s-4);
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        color: var(--text-muted);
      }
      .flow__node + .flow__node::before {
        content: '';
        position: absolute;
        top: calc(-1 * var(--s-3) - 1px);
        left: 50%;
        width: 1px;
        height: var(--s-3);
        background: var(--border);
      }
      .flow__node--warn {
        color: var(--text-dim);
        border-style: dashed;
      }
      .flow__node--ok {
        color: var(--text);
      }
      .flow__node--end {
        background: var(--accent-soft);
        border-color: rgba(217, 107, 130, 0.4);
        color: var(--text);
        font-weight: 600;
      }
      .arch__note {
        color: var(--text-muted);
        font-size: var(--fs-sm);
      }
      .arch__vs {
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .arch__vs span {
        font-family: var(--font-code);
        font-weight: 500;
        font-size: var(--fs-sm);
        color: var(--text-dim);
        border: 1px solid var(--border);
        border-radius: var(--r-pill);
        width: 44px;
        height: 44px;
        display: grid;
        place-items: center;
        background: var(--bg);
      }

      /* ===================== Proof contrast ===================== */
      .proof-contrast {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--s-8);
        margin-bottom: var(--s-16);
      }
      .proof-card {
        border: 1px solid var(--border);
        border-radius: var(--r-card);
        padding: var(--s-12);
        background: var(--surface);
      }
      .proof-card--us {
        border-color: rgba(217, 107, 130, 0.4);
        box-shadow: 0 10px 50px -22px rgba(217, 107, 130, 0.4);
      }
      .proof-card__metric {
        font-family: var(--font-head);
        font-weight: 700;
        font-size: var(--fs-4xl);
        line-height: 1;
        letter-spacing: -0.02em;
        margin-bottom: var(--s-3);
        color: var(--text-dim);
      }
      .proof-card--us .proof-card__metric {
        color: var(--text);
      }
      .proof-card__label {
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-muted);
        margin-bottom: var(--s-6);
      }
      .proof-card__note {
        color: var(--text-muted);
        font-size: var(--fs-base);
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        border-top: 1px solid var(--border);
      }
      .stat {
        padding: var(--s-12) var(--s-8) var(--s-8);
        border-bottom: 1px solid var(--border);
        border-right: 1px solid var(--border);
      }
      .stat:first-child {
        border-left: 1px solid var(--border);
      }
      .stat__num {
        font-family: var(--font-head);
        font-weight: 700;
        font-size: var(--fs-4xl);
        line-height: 1;
        letter-spacing: -0.02em;
        margin-bottom: var(--s-4);
        display: flex;
        align-items: baseline;
        gap: var(--s-3);
      }
      /* The 100× tile is a TARGET, not a measured result — styled as an outline,
         tagged "target", so it never reads as a third measured stat. */
      .stat--target {
        background: repeating-linear-gradient(
          -45deg,
          transparent,
          transparent 9px,
          rgba(255, 255, 255, 0.015) 9px,
          rgba(255, 255, 255, 0.015) 10px
        );
      }
      .stat__target-num {
        color: var(--text-dim);
        -webkit-text-stroke: 1px var(--accent);
        text-stroke: 1px var(--accent);
      }
      .stat__tag {
        font-family: var(--font-code);
        font-size: 0.6rem;
        font-weight: 500;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--accent);
        border: 1px solid rgba(217, 107, 130, 0.4);
        border-radius: var(--r-pill);
        padding: 2px 8px;
        align-self: center;
      }
      .stat__label {
        font-size: var(--fs-md);
        font-weight: 600;
        margin-bottom: var(--s-1);
      }
      .stat__sub {
        color: var(--text-muted);
        font-size: var(--fs-sm);
      }
      .stats__foot {
        margin-top: var(--s-8);
        color: var(--text-muted);
        font-size: var(--fs-sm);
        max-width: 76ch;
      }

      .features {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--s-8) var(--s-12);
        list-style: none;
        margin: var(--s-24) 0 0;
        padding: 0;
        position: relative;
      }
      /* Cursor spotlight: a soft rose light tracks the pointer (--mx/--my set in JS). */
      .features::before {
        content: '';
        position: absolute;
        inset: -8% -3%;
        pointer-events: none;
        z-index: 0;
        border-radius: var(--r-card);
        background: radial-gradient(
          260px circle at var(--mx, 50%) var(--my, -30%),
          rgba(217, 107, 130, 0.14),
          transparent 60%
        );
        opacity: 0;
        transition: opacity 0.4s var(--ease);
      }
      .features:hover::before {
        opacity: 1;
      }
      .feature {
        position: relative;
        z-index: 1;
        padding-top: var(--s-8);
        border-top: 1px solid var(--border);
        transition: border-color var(--dur) var(--ease), transform var(--dur) var(--ease);
      }
      .feature:hover {
        border-top-color: var(--accent);
        transform: translateY(-3px);
      }
      .feature__icon {
        display: inline-grid;
        place-items: center;
        width: 40px;
        height: 40px;
        border-radius: var(--r-control);
        border: 1px solid var(--border);
        color: var(--accent);
        margin-bottom: var(--s-6);
      }
      .feature__title {
        font-size: var(--fs-lg);
        font-weight: 600;
        margin-bottom: var(--s-4);
      }
      .feature__body {
        color: var(--text-muted);
      }
      .feature__body code {
        color: var(--text);
        background: var(--surface-2);
        padding: 1px 5px;
        border-radius: 5px;
      }
      .features__note {
        margin-top: var(--s-16);
        text-align: center;
        color: var(--text-muted);
      }

      .story {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: var(--s-12);
        align-items: center;
      }
      .story__arrow {
        display: grid;
        place-items: center;
        color: var(--text-dim);
      }
      .story__result {
        margin: 0;
      }
      .preview {
        position: relative;
        aspect-ratio: 16 / 9;
        width: 100%;
        border-radius: var(--r-card);
        border: 1px solid var(--border);
        background: var(--bg-deep);
        overflow: hidden;
        display: grid;
        place-content: center;
        box-shadow: var(--elev-card);
      }
      .preview__badge {
        position: absolute;
        top: var(--s-3);
        right: var(--s-3);
        font-family: var(--font-code);
        font-size: var(--fs-sm);
        color: var(--text-muted);
        background: rgba(8, 8, 10, 0.7);
        border: 1px solid var(--border);
        border-radius: var(--r-pill);
        padding: 2px var(--s-3);
      }
      .preview__text {
        font-family: var(--font-head);
        font-weight: 700;
        font-size: clamp(2rem, 6vw, 3.4rem);
        letter-spacing: -0.02em;
        color: var(--text);
      }
      .preview__bar {
        position: absolute;
        left: 12%;
        right: 12%;
        bottom: 16%;
        height: 6px;
        border-radius: var(--r-pill);
        background: var(--accent);
      }
      .story__caption {
        margin-top: var(--s-4);
        color: var(--text-muted);
        font-size: var(--fs-sm);
      }

      /* Reserve the hero stage's 16:9 box so the <video> can't shift layout. */
      .live__frame {
        aspect-ratio: 16 / 9;
        width: 100%;
      }

      /* ===================== Credibility strip ===================== */
      .creds {
        border-bottom: 1px solid var(--border);
        padding-block: var(--s-16);
      }
      .creds__inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: var(--s-12);
      }
      .creds__list {
        display: grid;
        grid-template-columns: repeat(4, auto);
        gap: var(--s-12);
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .creds__item {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .creds__k {
        font-family: var(--font-head);
        font-weight: 600;
        font-size: var(--fs-lg);
        color: var(--text);
      }
      .creds__v {
        font-size: var(--fs-sm);
        color: var(--text-muted);
      }
      .creds__cta {
        flex: none;
      }

      .cta {
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        padding-block: var(--s-32);
      }
      .cta__inner {
        text-align: center;
        max-width: 60ch;
        margin-inline: auto;
      }
      .cta__title {
        font-size: var(--fs-3xl);
        font-weight: 600;
        margin-bottom: var(--s-6);
        letter-spacing: -0.02em;
      }
      .cta__sub {
        color: var(--text-muted);
        font-size: var(--fs-md);
        margin-bottom: var(--s-8);
      }

      .footer {
        padding-top: var(--s-20);
      }
      .footer__inner {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: var(--s-8);
        padding-bottom: var(--s-16);
      }
      .footer__tag {
        color: var(--text-muted);
        margin-top: var(--s-4);
        max-width: 38ch;
      }
      .footer__nav {
        display: flex;
        flex-direction: column;
        gap: var(--s-3);
      }
      .footer__col-title {
        font-family: var(--font-head);
        font-size: var(--fs-base);
        font-weight: 600;
        color: var(--text);
        margin-bottom: var(--s-3);
      }
      .footer__nav a {
        color: var(--text-muted);
        font-weight: 500;
      }
      .footer__nav a:hover {
        color: var(--text);
      }
      .footer__bottom {
        display: flex;
        flex-wrap: wrap;
        gap: var(--s-4);
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid var(--border);
        padding-block: var(--s-6);
        color: var(--text-muted);
        font-size: var(--fs-sm);
      }
      .footer__bottom a {
        color: var(--text-muted);
        font-family: var(--font-code);
      }
      .footer__bottom a:hover {
        color: var(--accent);
      }
      /* Trademark / non-affiliation disclaimer — fine print, but present. */
      .footer__legal {
        padding-block: var(--s-2) var(--s-16);
      }
      .footer__legal p {
        color: var(--text-dim);
        font-size: 0.78rem;
        line-height: 1.65;
        max-width: 92ch;
      }
      .footer__legal a {
        color: var(--text-dim);
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      .footer__legal a:hover {
        color: var(--text-muted);
      }

      /* Pre-hide the above-the-fold hero before paint (the head inline script
         adds html.anim only when motion is allowed) so its entrance can't flash. */
      :global(html.anim) .hero__copy > *,
      :global(html.anim) .hero__stage {
        opacity: 0;
      }

      /* ===================== Lights & effects =====================
         All motion-only — gated behind prefers-reduced-motion so the page is
         calm and fully legible when reduced motion is requested. */
      @keyframes bd-rotate {
        to {
          --bd-angle: 360deg;
        }
      }
      @keyframes node-flow {
        0%,
        55%,
        100% {
          box-shadow: 0 0 0 0 transparent;
        }
        14% {
          box-shadow: 0 0 16px -3px rgba(217, 107, 130, 0.55);
        }
      }
      @keyframes wash-breathe {
        from {
          transform: translate3d(0, 0, 0) scale(1);
          opacity: 0.7;
        }
        to {
          transform: translate3d(-4%, 3%, 0) scale(1.18);
          opacity: 1;
        }
      }
      @keyframes atmos-drift {
        from {
          transform: translate3d(0, 0, 0);
        }
        to {
          transform: translate3d(4%, -3%, 0);
        }
      }
      @keyframes scroll-cue {
        0% {
          transform: translateY(-100%);
        }
        100% {
          transform: translateY(100%);
        }
      }
      @media (prefers-reduced-motion: no-preference) {
        /* A light sweeps the ONDA column's rose border (conic gradient masked to
           the edge, rotated via the @property angle). */
        .arch__col--onda::before {
          content: '';
          position: absolute;
          inset: -1px;
          border-radius: inherit;
          padding: 1.5px;
          background: conic-gradient(
            from var(--bd-angle),
            transparent 0deg,
            transparent 250deg,
            #e89aab 300deg,
            #f6d9df 330deg,
            #e89aab 360deg
          );
          -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
          -webkit-mask-composite: xor;
          mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
          mask-composite: exclude;
          pointer-events: none;
          animation: bd-rotate 5.5s linear infinite;
        }
        /* A pulse of glow races down the ONDA pipeline nodes, like data through it. */
        .arch__col--onda .flow__node {
          animation: node-flow 4.2s ease-in-out infinite;
        }
        .arch__col--onda .flow__node:nth-child(1) {
          animation-delay: 0s;
        }
        .arch__col--onda .flow__node:nth-child(2) {
          animation-delay: 0.45s;
        }
        .arch__col--onda .flow__node:nth-child(3) {
          animation-delay: 0.9s;
        }
        .arch__col--onda .flow__node:nth-child(4) {
          animation-delay: 1.35s;
        }
        /* The hero aurora slowly breathes. */
        .hero__wash {
          animation: wash-breathe 14s ease-in-out infinite alternate;
        }
        /* Ambient colour fields drift on their own slow clocks. */
        .atmos__blob--rose {
          animation: atmos-drift 20s ease-in-out infinite alternate;
        }
        .atmos__blob--violet {
          animation: atmos-drift 26s ease-in-out infinite alternate-reverse;
        }
        .atmos__blob--deep {
          animation: atmos-drift 32s ease-in-out infinite alternate;
        }
        /* A light glides down the hero scroll cue. */
        .hero__scroll-line::after {
          content: '';
          display: block;
          width: 100%;
          height: 40%;
          background: var(--accent);
          animation: scroll-cue 2.4s ease-in-out infinite;
        }
        /* The Studio pill gently breathes its glow to draw the eye (pauses on hover). */
        .onda-landing .nav__links a.nav__studio-link {
          animation: studio-pulse 3.2s ease-in-out infinite;
        }
        .onda-landing .nav__links a.nav__studio-link:hover {
          animation-play-state: paused;
        }
        .nav__studio-spark {
          animation: studio-spark 3.2s ease-in-out infinite;
        }
      }
      @keyframes studio-pulse {
        0%,
        100% {
          box-shadow: 0 0 0 1px rgba(176, 108, 255, 0.45), 0 6px 22px -6px var(--studio-glow);
        }
        50% {
          box-shadow: 0 0 0 1px var(--studio), 0 8px 30px 0 rgba(176, 108, 255, 0.55);
        }
      }
      @keyframes studio-spark {
        0%,
        100% {
          transform: rotate(0deg) scale(1);
          opacity: 0.85;
        }
        50% {
          transform: rotate(90deg) scale(1.18);
          opacity: 1;
        }
      }

      @media (max-width: 1024px) {
        .hero__inner {
          gap: var(--s-12);
        }
        .features {
          grid-template-columns: repeat(2, 1fr);
        }
        .footer__inner {
          grid-template-columns: 1fr 1fr;
        }
        .footer__brand {
          grid-column: 1 / -1;
        }
        .creds__inner {
          gap: var(--s-8);
        }
        .creds__list {
          grid-template-columns: repeat(2, auto);
          gap: var(--s-8) var(--s-12);
        }
      }
      @media (max-width: 768px) {
        .section {
          padding-block: var(--s-20);
        }
        .hero {
          padding-block: var(--s-16) var(--s-20);
        }
        .section__title,
        .cta__title {
          font-size: var(--fs-2xl);
        }
        .arch {
          grid-template-columns: 1fr;
          gap: var(--s-8);
        }
        .arch__vs {
          padding: var(--s-2) 0;
        }
        .proof-contrast {
          grid-template-columns: 1fr;
        }
        .stats {
          grid-template-columns: 1fr;
          border: 1px solid var(--border);
          border-bottom: 0;
        }
        .stat {
          border-right: 0;
          border-left: 0;
        }
        .stat:first-child {
          border-left: 0;
        }
        .story {
          grid-template-columns: 1fr;
          gap: var(--s-8);
        }
        .story__arrow {
          transform: rotate(90deg);
        }
        .nav__toggle {
          display: inline-flex;
          margin-left: auto;
        }
        /* Collapse the links into a full-width dropdown panel under the bar. */
        .nav__links {
          display: none;
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          flex-direction: column;
          gap: 0;
          margin-left: 0;
          padding: var(--s-2) var(--s-6) var(--s-4);
          background: var(--bg);
          border-bottom: 1px solid var(--border);
          box-shadow: 0 24px 48px -24px rgba(0, 0, 0, 0.7);
        }
        .nav.is-open .nav__links {
          display: flex;
        }
        .nav__links a:not(.nav__studio-link) {
          min-height: 48px;
          display: flex;
          align-items: center;
          padding: var(--s-2) 0;
          border-bottom: 1px solid var(--border);
        }
        /* Studio stays a pill — full-width, centered, as the menu's standout CTA. */
        .onda-landing .nav__links a.nav__studio-link {
          justify-content: center;
          margin-top: var(--s-4);
          padding-block: 11px;
        }
        .hero__scroll {
          display: none;
        }
      }
      @media (max-width: 480px) {
        .container {
          padding-inline: var(--s-4);
        }
        .features {
          grid-template-columns: 1fr;
        }
        .footer__inner {
          grid-template-columns: 1fr;
        }
        .creds__list {
          grid-template-columns: 1fr;
        }
        .code-card__pre {
          font-size: 0.8rem;
          padding: var(--s-4);
        }
      }

      /* ===================== Hero (stacked: lede + live stage) ===================== */
      .hero__inner {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--s-12);
      }
      .hero__lede {
        max-width: 880px;
        margin-inline: auto;
        text-align: center;
      }
      .hero__lede .hero__mark,
      .hero__lede .hero__sub {
        margin-inline: auto;
      }
      .hero__lede .hero__actions,
      .hero__lede .hero__chips {
        justify-content: center;
      }
      .hero__stage {
        position: relative;
        z-index: 1;
        width: 100%;
        max-width: 1100px;
        margin: 0 auto;
      }
      .hero__stage-frame {
        border-radius: var(--r-card);
        overflow: hidden;
        border: 1px solid var(--border);
        background: #050509;
        /* Rose glow to match the wave + the engine's accent — the hero is the
           engine's moment; Studio's violet is reserved for the Studio zone. */
        box-shadow: var(--elev-card), 0 30px 90px -24px rgba(217, 107, 130, 0.3);
      }
      .hero__video {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
      .hero__stage-cap {
        margin-top: var(--s-4);
        text-align: center;
        color: var(--text-muted);
        font-size: var(--fs-sm);
      }
      .hero__stage-cap code {
        color: var(--text);
        font-family: var(--font-code);
      }

      /* ===================== Studio (the product — one earned section) ============= */
      .studio__card {
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: var(--s-12) var(--s-16);
        align-items: center;
        padding: clamp(28px, 4vw, 56px);
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(176, 108, 255, 0.1), rgba(124, 92, 255, 0.04)),
          var(--surface);
        border: 1px solid rgba(176, 108, 255, 0.22);
        box-shadow: var(--elev-card), 0 0 100px -24px rgba(176, 108, 255, 0.22);
      }
      .studio__eyebrow {
        color: var(--studio);
      }
      /* The title's highlighted phrase ("Direct it.") in Studio's violet, not rose. */
      .studio .accent-text {
        color: var(--studio);
      }
      .studio__title {
        margin-bottom: var(--s-6);
      }
      .studio__lede {
        margin-bottom: var(--s-8);
        max-width: 56ch;
      }
      .studio__actions {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: var(--s-3);
      }
      .studio__note {
        color: var(--text-dim);
        font-size: var(--fs-sm);
      }
      .studio__visual {
        display: flex;
        flex-direction: column;
        gap: var(--s-3);
      }
      .studio__prompt {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 16px;
        border-radius: 12px;
        background: var(--bg-deep);
        border: 1px solid var(--border);
        color: var(--text-muted);
        font-family: var(--font-code);
        font-size: var(--fs-sm);
      }
      .studio__prompt-dot {
        flex: none;
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: var(--studio);
        box-shadow: 0 0 12px var(--studio);
      }
      .studio__flow {
        display: flex;
        align-items: center;
        gap: var(--s-3);
        color: var(--text-dim);
        font-family: var(--font-code);
        font-size: var(--fs-sm);
      }
      .studio__flow-line {
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--border), transparent);
      }
      .studio__flow-chip {
        white-space: nowrap;
        color: var(--studio);
      }
      .studio__out {
        position: relative;
        aspect-ratio: 16 / 9;
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid var(--border);
        display: grid;
        place-items: center;
        background: radial-gradient(120% 130% at 30% 8%, rgba(176, 108, 255, 0.38), transparent 55%),
          radial-gradient(100% 120% at 92% 100%, rgba(69, 214, 255, 0.22), transparent 50%), #0a0a14;
      }
      .studio__out-play {
        position: absolute;
        top: 13px;
        left: 16px;
        color: rgba(255, 255, 255, 0.7);
        font-size: 13px;
      }
      .studio__out-word {
        font-family: var(--font-head);
        font-weight: 700;
        font-size: clamp(2.4rem, 6vw, 3.6rem);
        letter-spacing: -0.02em;
        background: linear-gradient(100deg, #c08bff, #9a6bff, #45d6ff);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .studio__out-meta {
        position: absolute;
        bottom: 13px;
        left: 16px;
        right: 16px;
        color: var(--text-dim);
        font-family: var(--font-code);
        font-size: 0.72rem;
      }
      @media (max-width: 900px) {
        .studio__card {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </body>
</html>
