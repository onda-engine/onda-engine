---
// ONDA home — the marketing landing. A standalone static page (not a Starlight
// doc); the docs live under /guide, /api, etc. CTAs link into the docs. Brand
// marks come from assets/brand (onda-studio): the rose-gradient wave (static in
// nav/footer, animated in the hero). Styles are scoped to this component.
//
// Structure is a four-chapter narrative — Hook → Problem → Architecture →
// Proof — then a credibility strip, the Studio upsell, and the CTA. The proof
// numbers are synced to the repo benchmark (apps/benchmark/README.md): the
// honest measured multiples, with 100× labelled as the architectural target.
const REPO = 'https://github.com/degueba/onda-engine'
const BENCH = `${REPO}/tree/main/apps/benchmark`
// ONDA Studio — the hosted product on top of the open engine. Point this at the
// live app (or a waitlist) when it ships; it's the only off-site, paid CTA.
const STUDIO_URL = 'https://studio.onda.video'
const year = new Date().getFullYear()
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ONDA — Motion graphics at GPU speed. No browser.</title>
    <meta
      name="description"
      content="ONDA is an open-source, GPU-native, browser-free motion-graphics engine in Rust. Author in React, render through a native GPU pipeline — no Chromium anywhere."
    />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0e0e12" />
    {/* Inline (not bundled) so the dark canvas paints on the very first frame —
        prevents a background flash on reload before the scoped CSS loads. */}
    <style is:inline>
      html,
      body {
        margin: 0;
        background: #0e0e12;
      }
    </style>
    <meta property="og:type" content="website" />
    <meta property="og:title" content="ONDA — Motion graphics at GPU speed. No browser." />
    <meta
      property="og:description"
      content="Open-source, GPU-native, browser-free motion-graphics engine in Rust. Author in React; render through a native GPU pipeline."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=clash-display@600,700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // Mark the document as motion-enabled BEFORE first paint so above-the-fold
      // elements can start hidden (no flash). Skipped under reduced-motion / no-JS,
      // where everything stays visible.
      if (!window.matchMedia || !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('anim')
      }
    </script>
    {/* react-grab (dev only): hover any element + ⌘C / Ctrl+C to copy its
        file / component / source for a coding agent. A plain Astro <script> so
        Vite bundles it and the bare import resolves; the DEV guard tree-shakes it
        out of the production build. */}
    <script>
      if (import.meta.env.DEV) import('react-grab')
    </script>
  </head>
  <body>
    <div class="onda-landing">
      <a class="skip-link" href="#main">Skip to content</a>

      <!-- Scroll-progress rail (top hairline that fills as you read). -->
      <div class="scroll-rail" aria-hidden="true"><span class="scroll-rail__fill"></span></div>

      <!-- Ambient atmosphere: slow-drifting colour fields behind everything. -->
      <div class="atmos" aria-hidden="true">
        <span class="atmos__blob atmos__blob--rose"></span>
        <span class="atmos__blob atmos__blob--violet"></span>
        <span class="atmos__blob atmos__blob--deep"></span>
      </div>

      <!-- ============ STICKY NAV ============ -->
      <header class="nav" id="site-nav">
        <div class="container nav__inner">
          <a class="brand" href="#top" aria-label="ONDA — home">
            <img class="brand__mark-img" src="/onda-mark.svg" alt="" width="88" height="22" />
            <span class="brand__word">ONDA</span>
          </a>
          <nav class="nav__links" id="nav-links" aria-label="Primary">
            <a href="#features">Features</a>
            <a href="/components">Components</a>
            <a href="/transitions">Transitions</a>
            <a href="/effects">Effects</a>
            <a href="/guide/introduction">Docs</a>
            <a class="nav__studio-link" href={STUDIO_URL} rel="noopener">
              <svg class="nav__studio-spark" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l1.9 6.6L20 10.5l-6.1 1.9L12 19l-1.9-6.6L4 10.5l6.1-1.9z"/></svg>
              Studio
            </a>
          </nav>
          <button class="nav__toggle" type="button" aria-expanded="false" aria-controls="nav-links" aria-label="Open menu">
            <svg class="nav__toggle-bars" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
            <svg class="nav__toggle-x" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M5 5l14 14M19 5 5 19"/></svg>
          </button>
        </div>
      </header>

      <main id="main">
        <span id="top"></span>

        <!-- ============ HERO (the hook) ============ -->
        <section class="hero" aria-labelledby="hero-title">
          <div class="hero__bg" data-parallax="0.18" aria-hidden="true">
            <div class="hero__wash"></div>
          </div>
          <div class="container hero__inner">
            <div class="hero__copy hero__lede">
              <img
                class="hero__mark"
                src="/onda-mark-animated.svg"
                alt="ONDA"
                width="216"
                height="54"
              />
              <p class="eyebrow">Open source · Rust · GPU-native</p>
              <h1 id="hero-title" class="hero__title">
                Motion graphics at <span class="accent-text">GPU speed</span>. No browser.
              </h1>
              <p class="hero__sub">
                Author compositions in React; render them through a native GPU pipeline —
                <strong>zero Chromium</strong> anywhere in the loop. The film below is rendered
                <strong>live, on your GPU</strong>, by the very same engine.
              </p>
              <div class="hero__actions">
                <a class="btn btn--primary" href="/guide/getting-started">Get started</a>
                <a class="btn btn--ghost" href={REPO} rel="noopener">
                  <svg class="btn__icon" width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                    <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.4 7.4 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z" />
                  </svg>
                  View on GitHub
                </a>
              </div>
              <ul class="hero__chips" aria-label="At a glance">
                <li>No DOM · No Chromium</li>
                <li>Vello GPU renderer</li>
                <li>MIT / Apache-2.0</li>
              </ul>
            </div>

            <figure class="hero__stage" aria-label="An ONDA composition rendered by the engine">
              <div class="live__frame hero__stage-frame">
                <video
                  class="hero__video"
                  src="/hero.mp4"
                  poster="/hero-poster.jpg"
                  autoplay
                  loop
                  muted
                  playsinline
                  aria-label="ONDA — the wave: a composition rendered by the engine"
                ></video>
              </div>
              <figcaption class="hero__stage-cap">
                Rendered frame-for-frame by the <code>@onda</code> engine — GPU-native, no browser.
                <strong>Authored in React. Exported to video.</strong>
              </figcaption>
            </figure>
          </div>
          <a class="hero__scroll" href="#architecture" aria-label="Scroll to read on">
            <span class="hero__scroll-line" aria-hidden="true"></span>
          </a>
        </section>

        <!-- ============ CHAPTER 01 — THE PROBLEM ============ -->
        <section class="section section--alt chapter" id="architecture" aria-labelledby="arch-title">
          <span class="chapter__num" aria-hidden="true">01</span>
          <div class="container">
            <header class="section__head">
              <p class="eyebrow"><span class="eyebrow__tick">01</span> The problem</p>
              <h2 id="arch-title" class="section__title">Every frame renders through a browser</h2>
              <p class="section__lede">
                Remotion drives each frame through a headless Chromium — DOM, CSS layout, a
                screenshot and IPC, on <em>every single frame</em>. ONDA compiles your scene to a
                graph and hands it straight to the GPU. Fewer hops, no DOM, no screenshot pipeline.
              </p>
            </header>
            <div class="arch">
              <article class="arch__col arch__col--remotion">
                <h3 class="arch__name">Remotion <span class="arch__tag arch__tag--muted">browser-based</span></h3>
                <ol class="flow" aria-label="Remotion render pipeline">
                  <li class="flow__node">React</li>
                  <li class="flow__node flow__node--warn">DOM</li>
                  <li class="flow__node flow__node--warn">Headless Chromium</li>
                  <li class="flow__node flow__node--warn">Screenshot per frame</li>
                  <li class="flow__node">Encode</li>
                  <li class="flow__node flow__node--end">Video</li>
                </ol>
                <p class="arch__note">Browser, DOM, CSS layout and IPC overhead on every single frame.</p>
              </article>
              <div class="arch__vs" aria-hidden="true"><span>vs</span></div>
              <article class="arch__col arch__col--onda">
                <h3 class="arch__name">ONDA <span class="arch__tag arch__tag--brand">GPU-native</span></h3>
                <ol class="flow" aria-label="ONDA render pipeline">
                  <li class="flow__node">React</li>
                  <li class="flow__node flow__node--ok">Scene graph</li>
                  <li class="flow__node flow__node--ok">Native GPU renderer</li>
                  <li class="flow__node flow__node--end">Frame &rarr; Video</li>
                </ol>
                <p class="arch__note">No browser anywhere. Deterministic, low-memory, high-concurrency per machine.</p>
              </article>
            </div>
          </div>
        </section>

        <!-- ============ CHAPTER 02 — THE ARCHITECTURE ============ -->
        <section class="section chapter" id="features" aria-labelledby="features-title">
          <span class="chapter__num" aria-hidden="true">02</span>
          <div class="container">
            <header class="section__head">
              <p class="eyebrow"><span class="eyebrow__tick">02</span> The architecture</p>
              <h2 id="features-title" class="section__title">One scene graph, straight to the GPU</h2>
              <p class="section__lede">
                The renderer is the product; React, JSON and AI are all adapters onto one
                universal scene graph. Author it like Remotion, finish it like a film, render it
                natively — no browser to install or babysit.
              </p>
            </header>

            <!-- JSX → video flow -->
            <div class="story">
              <figure class="code-card" aria-label="Render commands using the onda CLI">
                <figcaption class="code-card__bar">
                  <span class="code-card__dots" aria-hidden="true"><i></i><i></i><i></i></span>
                  <span class="code-card__file">terminal</span>
                  <button class="code-card__copy" type="button" data-copy="cli-code" aria-label="Copy commands to clipboard">Copy</button>
                </figcaption>
                <pre class="code-card__pre"><code id="cli-code"><span class="tok-comment"># render through the GPU (Vello) backend — no browser involved</span>
<span class="tok-fn">onda</span> render scene.json out.png
<span class="tok-fn">onda</span> export movie.json out.mp4 <span class="tok-attr">--backend</span> vello</code></pre>
              </figure>
              <div class="story__arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
              </div>
              <figure class="story__result" aria-label="Rendered frame preview">
                <div class="preview" role="img" aria-label="A rendered 1920×1080 frame: the words ‘GPU-native’ over a near-black background with a rose underline bar.">
                  <span class="preview__badge">1920 × 1080 · MP4</span>
                  <span class="preview__text">GPU-native</span>
                  <span class="preview__bar"></span>
                </div>
                <figcaption class="story__caption">Same scene, deterministic output — rendered straight from the scene graph.</figcaption>
              </figure>
            </div>

            <!-- What's inside -->
            <ul class="features" role="list">
              <li class="card feature">
                <span class="feature__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12c3-5 6-5 9 0s6 5 9 0"/><path d="M3 17c3-5 6-5 9 0s6 5 9 0"/></svg>
                </span>
                <h3 class="feature__title">GPU-native Vello renderer</h3>
                <p class="feature__body">Anti-aliased fills and strokes, real rounded rects, arbitrary Bézier paths, linear/radial gradients, clip masks, native per-glyph vector text, and <code>&lt;Svg&gt;</code> import that expands logos into vector nodes.</p>
              </li>
              <li class="card feature">
                <span class="feature__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="m8 6-6 6 6 6"/><path d="m16 6 6 6-6 6"/></svg>
                </span>
                <h3 class="feature__title">Author in React / JSX</h3>
                <p class="feature__body"><code>&lt;Composition&gt;</code>, <code>&lt;Rect&gt;</code>, <code>&lt;Path&gt;</code>, <code>&lt;Sequence&gt;</code>, <code>useCurrentFrame</code>, <code>interpolate</code>, <code>spring</code>. The Remotion DX you know, compiled to a scene graph.</p>
              </li>
              <li class="card feature">
                <span class="feature__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><circle cx="5" cy="5" r="2"/><circle cx="19" cy="5" r="2"/><circle cx="12" cy="20" r="2"/><path d="M7 6.5 10 10m4 0 3-3.5M12 15v3"/></svg>
                </span>
                <h3 class="feature__title">Universal scene graph</h3>
                <p class="feature__body">React, JSON or an AI agent all emit the same graph. One runtime renders it — the renderer is the platform, not any single front end.</p>
              </li>
              <li class="card feature">
                <span class="feature__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v3m0 12v3M3 12h3m12 0h3M5.6 5.6l2.1 2.1m8.6 8.6 2.1 2.1m0-12.8-2.1 2.1m-8.6 8.6-2.1 2.1"/><circle cx="12" cy="12" r="3.2"/></svg>
                </span>
                <h3 class="feature__title">Cinematic finishing</h3>
                <p class="feature__body">A render-to-texture effects stack: blur, bloom, film grade, grain, depth-of-field and motion blur — plus 3D layers and extruded text and logos. Land AI media beautifully.</p>
              </li>
              <li class="card feature">
                <span class="feature__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h3l2.5-7 4 16 3-9 1.5 4H22"/></svg>
                </span>
                <h3 class="feature__title">Native media &amp; audio</h3>
                <p class="feature__body">Draw <code>&lt;Image&gt;</code> and <code>&lt;Video&gt;</code> straight into the scene; decode audio with FFT spectrum, beat-sync and a declarative synth — sound is part of the graph, not bolted on.</p>
              </li>
              <li class="card feature">
                <span class="feature__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18"/><path d="m23 7-7 5 7 5z" transform="scale(0)"/><circle cx="7" cy="6.5" r=".6" fill="currentColor"/></svg>
                </span>
                <h3 class="feature__title">CPU + GPU backends</h3>
                <p class="feature__body"><code>--backend auto|vello|cpu</code>. The tiny-skia CPU reference renders fills, strokes, gradients and paths <em>byte-identical</em> to Vello for deterministic CI. Export PNG / GIF / MP4 from the <code>onda</code> CLI.</p>
              </li>
            </ul>
            <div class="features__note">
              <p>Built on a Rust workspace, fully open source under <strong>MIT OR Apache-2.0</strong>. <a href="/guide/introduction">Read the docs →</a></p>
            </div>
          </div>
        </section>

        <!-- ============ CHAPTER 03 — THE PROOF ============ -->
        <section class="section section--alt chapter" id="why" aria-labelledby="why-title">
          <span class="chapter__num" aria-hidden="true">03</span>
          <div class="container">
            <header class="section__head">
              <p class="eyebrow"><span class="eyebrow__tick">03</span> The proof</p>
              <h2 id="why-title" class="section__title">Remotion pays for the browser. ONDA pays for the pixels.</h2>
              <p class="section__lede">
                The advantage is <strong>architectural</strong>, not a single magic benchmark.
                Remotion's cost is nearly <em>content-independent</em>; ONDA's tracks what you
                actually draw — so the gap widens as scenes get heavier.
              </p>
            </header>

            <!-- The contrast that explains the numbers -->
            <div class="proof-contrast">
              <article class="proof-card proof-card--them">
                <p class="proof-card__metric">~26 fps</p>
                <p class="proof-card__label">Remotion, per worker</p>
                <p class="proof-card__note">Holds ~26 fps whether the scene has <strong>6 nodes or 201</strong>. You're paying the browser tax — layout, paint, screenshot, IPC — not for the drawing.</p>
              </article>
              <article class="proof-card proof-card--us">
                <p class="proof-card__metric"><span class="accent-text">217 fps</span></p>
                <p class="proof-card__label">ONDA GPU, the heavy scene</p>
                <p class="proof-card__note">Renders a <strong>33× heavier</strong> scene (201 nodes) only 1.4× slower than trivial. One parallel pass, not N browser screenshots. Cost tracks the graphics.</p>
              </article>
            </div>

            <!-- Measured multiples + the labelled target -->
            <div class="stats" role="list">
              <div class="stat" role="listitem">
                <p class="stat__num"><span class="accent-text" data-count="5.4" data-decimals="1" data-suffix="×">5.4×</span></p>
                <p class="stat__label">faster export → MP4</p>
                <p class="stat__sub">one ONDA process vs one Remotion worker — same libx264 encoder, 1080p trivial scene</p>
              </div>
              <div class="stat" role="listitem">
                <p class="stat__num"><span class="accent-text" data-count="8.5" data-decimals="1" data-suffix="×">8.5×</span></p>
                <p class="stat__label">per thread, heavy scene</p>
                <p class="stat__sub">ONDA GPU vs a Remotion worker at 201 nodes — up from 3.8× on a trivial scene</p>
              </div>
              <div class="stat stat--target" role="listitem">
                <p class="stat__num"><span class="stat__target-num">100×</span> <span class="stat__tag">target</span></p>
                <p class="stat__label">architectural ceiling</p>
                <p class="stat__sub">the realized goal on real workloads — complex scenes × GPU present × cold-start × concurrency. Not a single-scene measurement.</p>
              </div>
            </div>
            <p class="stats__foot">
              Measured on an Apple M4 Pro at 1080p, 120 frames, with libx264 on both engines — so
              the win is the no-browser raster, not the encoder. Numbers vary by scene, hardware and
              config. <a href="/benchmark">Full method &amp; reproduction →</a>
            </p>
          </div>
        </section>

        <!-- ============ CREDIBILITY STRIP ============ -->
        <section class="creds" aria-label="Why teams trust ONDA">
          <div class="container creds__inner">
            <ul class="creds__list" role="list">
              <li class="creds__item">
                <span class="creds__k">MIT / Apache-2.0</span>
                <span class="creds__v">Permissive, dual-licensed</span>
              </li>
              <li class="creds__item">
                <span class="creds__k">Pure Rust</span>
                <span class="creds__v">One workspace, no Chromium</span>
              </li>
              <li class="creds__item">
                <span class="creds__k">Deterministic</span>
                <span class="creds__v">Byte-identical CPU reference</span>
              </li>
              <li class="creds__item">
                <span class="creds__k">Engine-rendered</span>
                <span class="creds__v">This page's hero is real output</span>
              </li>
            </ul>
            <a class="btn btn--ghost creds__cta" href={REPO} rel="noopener">
              <svg class="btn__icon" width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.4 7.4 0 0 1 2-.27c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z" />
              </svg>
              Star on GitHub
            </a>
          </div>
        </section>

        <!-- ============ STUDIO (the product) ============ -->
        <section class="section studio" id="studio" aria-labelledby="studio-title">
          <div class="container">
            <div class="studio__card">
              <div class="studio__copy">
                <p class="eyebrow studio__eyebrow">ONDA Studio · the AI director</p>
                <h2 id="studio-title" class="section__title studio__title">
                  Don't build it. <span class="accent-text">Direct it.</span>
                </h2>
                <p class="section__lede studio__lede">
                  Describe the video. Studio directs the engine and ships it —
                  <strong>broadcast-ready, the first time.</strong>
                </p>
                <div class="studio__actions">
                  <a class="btn btn--studio" href={STUDIO_URL} rel="noopener">Start with Studio →</a>
                  <span class="studio__note">Engine: free &amp; open source. Studio: the hosted director on top.</span>
                </div>
              </div>

              <div class="studio__visual" aria-hidden="true">
                <div class="studio__prompt">
                  <span class="studio__prompt-dot"></span>
                  <span class="studio__prompt-text">"15-second launch film for our Series A — punchy, on-brand"</span>
                </div>
