    <script>
      // Motion (motion.dev — the framework-agnostic engine behind Framer Motion):
      // a tasteful entrance + scroll-reveal pass, scroll-linked parallax, a read
      // progress rail and animated stat count-ups. Plus sticky-nav shadow and the
      // code-card copy buttons. Honors prefers-reduced-motion (skips all motion).
      import { animate, inView, stagger, scroll } from 'motion'

      // Sticky nav: hairline + tint once scrolled.
      const nav = document.getElementById('site-nav')
      if (nav) {
        const onScroll = () => nav.classList.toggle('is-scrolled', window.scrollY > 8)
        onScroll()
        window.addEventListener('scroll', onScroll, { passive: true })

        // Mobile menu toggle (the nav links collapse behind a hamburger ≤768px).
        const toggle = nav.querySelector('.nav__toggle')
        const navLinks = document.getElementById('nav-links')
        if (toggle && navLinks) {
          const setOpen = (open) => {
            nav.classList.toggle('is-open', open)
            toggle.setAttribute('aria-expanded', open ? 'true' : 'false')
            toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu')
          }
          toggle.addEventListener('click', () => setOpen(!nav.classList.contains('is-open')))
          for (const a of navLinks.querySelectorAll('a')) a.addEventListener('click', () => setOpen(false))
          document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') setOpen(false)
          })
        }
      }

      // Copy-to-clipboard on code cards.
      for (const btn of document.querySelectorAll('.code-card__copy')) {
        btn.addEventListener('click', () => {
          const id = btn.getAttribute('data-copy')
          const target = id ? document.getElementById(id) : null
          if (!target) return
          navigator.clipboard
            ?.writeText(target.innerText)
            .then(() => {
              btn.textContent = 'Copied'
              btn.classList.add('is-copied')
              window.setTimeout(() => {
                btn.textContent = 'Copy'
                btn.classList.remove('is-copied')
              }, 1600)
            })
            .catch(() => {})
        })
      }

      // Read-progress rail — scroll-linked, low-risk even under reduced motion
      // (it's an informational indicator, not autonomous motion).
      const rail = document.querySelector('.scroll-rail__fill')
      if (rail) scroll(animate(rail, { scaleX: [0, 1] }, { ease: 'linear' }))

      const reduce = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches
      if (!reduce) {
        // Expo-out — the "expensive" easing curve.
        const EASE = [0.16, 1, 0.3, 1]
        const hide = (els) => {
          for (const el of els) el.style.opacity = '0'
        }

        // Hero entrance: stagger the copy, slide the stage in.
        const heroEls = Array.from(document.querySelectorAll('.hero__copy > *'))
        hide(heroEls)
        animate(
          heroEls,
          { opacity: [0, 1], y: [16, 0] },
          { delay: stagger(0.07), duration: 0.6, ease: EASE },
        )
        const stage = document.querySelector('.hero__stage')
        if (stage) {
          stage.style.opacity = '0'
          animate(
            stage,
            { opacity: [0, 1], y: [24, 0], scale: [0.985, 1] },
            { duration: 0.8, delay: 0.22, ease: EASE },
          )
        }

        // Scroll-linked parallax: drift any [data-parallax] element as its
        // section crosses the viewport. Subtle (transform-only, GPU-friendly) —
        // not scroll-jacking. The value is the fraction of viewport height to drift.
        for (const el of document.querySelectorAll('[data-parallax]')) {
          const depth = parseFloat(el.getAttribute('data-parallax') || '0') * 140
          scroll(animate(el, { y: [`${-depth}px`, `${depth}px`] }, { ease: 'linear' }), {
            target: el.closest('section') || el,
            offset: ['start end', 'end start'],
          })
        }

        // Reveal one element when it scrolls into view.
        const reveal = (el, keyframes, opts = {}) => {
          if (!el) return
          el.style.opacity = '0'
          inView(
            el,
            () => {
              animate(el, { opacity: [0, 1], ...keyframes }, { duration: 0.7, ease: EASE, ...opts })
            },
            { amount: 0.2 },
          )
        }

        // Reveal a container's children with a stagger.
        const group = (container, childSel, keyframes) => {
          if (!container) return
          const kids = Array.from(container.querySelectorAll(childSel))
          hide(kids)
          inView(
            container,
            () => {
              animate(
                kids,
                { opacity: [0, 1], ...keyframes },
                { delay: stagger(0.08), duration: 0.55, ease: EASE },
              )
            },
            { amount: 0.15 },
          )
        }

        for (const head of document.querySelectorAll('.section__head')) reveal(head, { y: [22, 0] })

        // Architecture: columns slide in from their sides, the "vs" pops.
        reveal(document.querySelector('.arch__col--remotion'), { x: [-24, 0] })
        reveal(document.querySelector('.arch__col--onda'), { x: [24, 0] })
        reveal(document.querySelector('.arch__vs'), { scale: [0.6, 1] }, { delay: 0.15, amount: 0.5 })

        // Staggered groups.
        group(document.querySelector('.features'), '.feature', { y: [22, 0] })
        group(document.querySelector('.stats'), '.stat', { y: [22, 0] })
        group(document.querySelector('.proof-contrast'), '.proof-card', { y: [22, 0] })
        group(document.querySelector('.creds__list'), '.creds__item', { y: [16, 0] })
        group(document.querySelector('.story'), '.code-card, .story__arrow, .story__result', {
          y: [18, 0],
        })

        for (const el of document.querySelectorAll('.cta__inner, .stats__foot, .features__note'))
          reveal(el, { y: [18, 0] })

        // Animated count-ups on the stat numbers (drive from 0 → target once
        // they scroll in). Static HTML already holds the final value as fallback.
        for (const el of document.querySelectorAll('[data-count]')) {
          const target = parseFloat(el.getAttribute('data-count') || '0')
          const decimals = parseInt(el.getAttribute('data-decimals') || '0', 10)
          const suffix = el.getAttribute('data-suffix') || ''
          let played = false
          inView(
            el,
            () => {
              if (played) return
              played = true
              animate(0, target, {
                duration: 1.1,
                ease: EASE,
                onUpdate: (v) => {
                  el.textContent = v.toFixed(decimals) + suffix
                },
              })
            },
            { amount: 0.6 },
          )
        }

        // Cursor spotlight: track the pointer over the feature grid (the CSS
        // ::before radial follows --mx/--my).
        const grid = document.querySelector('.features')
        if (grid) {
          grid.addEventListener(
            'pointermove',
            (e) => {
              const r = grid.getBoundingClientRect()
              grid.style.setProperty('--mx', `${e.clientX - r.left}px`)
              grid.style.setProperty('--my', `${e.clientY - r.top}px`)
            },
            { passive: true },
          )
        }
      }
    </script>

