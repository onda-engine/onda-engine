{
  "name": "@onda-engine/cinema",
  "version": "0.1.2",
  "description": "Render a timeline composition payload (scenes/tracks/entries + choreography + transitions) to an @onda-engine/react element — the spec→engine renderer ONDA Studio uses instead of its Remotion renderer.",
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "onda-inspect": "./bin/onda-inspect.mjs"
  },
  "files": ["dist", "bin"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@onda-engine/components": "workspace:*",
    "@onda-engine/react": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "react": "^19.2.0",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onda-engine/onda-engine.git",
    "directory": "packages/cinema"
  }
}
