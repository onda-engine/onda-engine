{
  "name": "@onda/cinema",
  "version": "0.0.0",
  "description": "Render a timeline composition payload (scenes/tracks/entries + choreography + transitions) to an @onda/react element — the spec→engine renderer ONDA Studio uses instead of its Remotion renderer.",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@onda/components": "workspace:*",
    "@onda/react": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "vitest": "^2.1.8"
  }
}
