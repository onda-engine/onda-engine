{
  "name": "@onda-engine/components",
  "version": "0.2.1",
  "description": "The Onda motion language \u2014 a Remotion-shaped choreography + component library for @onda-engine/react. Ported from ondajs.",
  "keywords": [
    "onda",
    "motion-graphics",
    "programmatic-video",
    "video",
    "react",
    "components",
    "kinetic-typography",
    "transitions",
    "data-visualization",
    "animation"
  ],
  "homepage": "https://onda.video",
  "bugs": "https://github.com/onda-engine/onda-engine/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onda-engine/onda-engine.git",
    "directory": "packages/components"
  },
  "license": "FSL-1.1-ALv2",
  "author": "Rodrigo Botelho",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "default": "./dist/manifest.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@onda-engine/react": "workspace:*",
    "@onda-engine/wasm": "workspace:*",
    "@onda-engine/wasm-audio": "workspace:*",
    "react": "^19.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
