{
  "name": "@onda/react",
  "version": "0.0.0",
  "description": "Write React, get an ONDA scene graph. A custom React renderer that compiles JSX into the engine's scene-graph JSON.",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "flubber": "^0.4.2",
    "react": "^19.2.0",
    "react-reconciler": "^0.33.0"
  },
  "devDependencies": {
    "@types/flubber": "^0.4.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-reconciler": "^0.33.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
