{
  "name": "@onda-engine/react",
  "version": "0.1.1",
  "description": "Write React, get an ONDA scene graph. A custom React renderer that compiles JSX into the engine's scene-graph JSON.",
  "keywords": [
    "onda",
    "motion-graphics",
    "programmatic-video",
    "video",
    "react",
    "react-renderer",
    "react-reconciler",
    "scene-graph",
    "gpu",
    "remotion-alternative",
    "animation"
  ],
  "homepage": "https://onda.video",
  "bugs": "https://github.com/onda-engine/onda-engine/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onda-engine/onda-engine.git",
    "directory": "packages/react"
  },
  "license": "FSL-1.1-ALv2",
  "author": "Rodrigo Botelho",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "flubber": "^0.4.2",
    "react": "^19.2.0",
    "react-reconciler": "^0.33.0"
  },
  "devDependencies": {
    "@types/flubber": "^0.4.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-reconciler": "^0.33.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  }
}
