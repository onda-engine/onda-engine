# Rust
/target
**/target
Cargo.lock.bak

# Node
node_modules
dist
.turbo
*.tsbuildinfo

# Astro generated cache/types
.astro

# WASM build output
pkg

# Editor / OS
.DS_Store
*.swp
.idea
.vscode/*
!.vscode/extensions.json

# ONDA render output (examples write here)
*.png
!docs/**/*.png
!apps/site/**/*.png
!assets/**/*.png
# Golden-frame test references must be tracked (the test diffs against them).
!packages/*/tests/golden/*.png
packages/*/tests/golden/*.actual.png
*.gif
*.mp4
!docs/**/*.gif
!docs/**/*.mp4
!apps/site/**/*.gif
!apps/site/**/*.mp4

# Logs
*.log

# Claude plugin workspace (not source). Unanchored so nested copies (e.g. inside
# packages/*) are ignored too.
.claude/

# Ruflo / claude-flow runtime workspace (not source)
.claude-flow/
.swarm/

# Ruflo runtime databases (machine-local, regenerable — not source)
*.rvf
*.rvf.lock
ruvector.db

# Generated example scene JSON
packages/react/examples/assets/svg.json

# VitePress build cache
**/.vitepress/cache/
refs/

# ONDA Studio MCP — local dev/test client config (points at ../onda-studio; not OSS-engine source)
/.mcp.json

# built preview app (regenerated)
apps/preview/dist/

# Embed-kit / vendor bundle output (scripts/build-embed-kit.sh). Covered by the
# unanchored `dist` rule above; explicit so the contract is visible.
/dist/embed-kit/
