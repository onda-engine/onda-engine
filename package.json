{
  "name": "onda-engine",
  "version": "0.0.0",
  "private": true,
  "description": "The source-available motion graphics engine. GPU-native, scene-graph-first, framework-agnostic.",
  "license": "FSL-1.1-ALv2",
  "type": "module",
  "packageManager": "pnpm@10.5.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "changeset:version": "changeset version && pnpm install --lockfile-only && pnpm format",
    "changeset:publish": "pnpm -r build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.7",
    "typescript": "^5.7.2"
  }
}
