{
  "name": "onda-engine-workspace",
  "version": "0.0.0",
  "description": "The source-available motion graphics engine. GPU-native, scene-graph-first, framework-agnostic.",
  "keywords": [
    "onda",
    "motion-graphics",
    "programmatic-video",
    "video",
    "gpu",
    "vello",
    "rust",
    "wasm",
    "scene-graph",
    "remotion-alternative",
    "react",
    "animation"
  ],
  "homepage": "https://onda.video",
  "bugs": "https://github.com/onda-engine/onda-engine/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onda-engine/onda-engine.git"
  },
  "license": "FSL-1.1-ALv2",
  "author": "Rodrigo Botelho",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "publish:npm": "pnpm -r build && pnpm --filter onda-engine publish --no-git-checks"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.2"
  },
  "private": true,
  "packageManager": "pnpm@10.5.0",
  "engines": {
    "node": ">=20"
  }
}
